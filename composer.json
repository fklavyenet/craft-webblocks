{
    "name": "fklavyenet/craft-webblocks",
    "description": "A portable website building toolkit for Craft CMS — create modern business websites with reusable content blocks, flexible page layouts, and built-in SEO.",
    "version": "1.10.0",
    "type": "craft-plugin",
    "keywords": ["craft", "cms", "website", "starter-kit", "blocks", "pages", "seo"],
    "license": "proprietary",
    "authors": [
        {
            "name": "Osman Bozdag",
            "homepage": "https://fklavye.net"
        }
    ],
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0.0",
        "craftcms/ckeditor": "^5.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "fklavyenet\\webblocks\\": "src/"
        }
    },
    "extra": {
        "name": "WebBlocks",
        "handle": "webblocks",
        "developer": "fklavyenet",
        "developerUrl": "https://fklavye.net",
        "documentationUrl": "https://github.com/fklavyenet/craft-webblocks",
        "changelogUrl": "https://raw.githubusercontent.com/fklavyenet/craft-webblocks/main/CHANGELOG.md",
        "schemaVersion": "1.0.0",
        "class": "fklavyenet\\webblocks\\WebBlocks"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    }
}
