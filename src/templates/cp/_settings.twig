{% import "_includes/forms" as forms %}

<h2>{{ "Email"|t('app') }}</h2>

{{ forms.textField({
    label:        "Default Admin Email"|t('webblocks'),
    id:           'adminEmail',
    name:         'adminEmail',
    type:         'email',
    instructions: "Fallback recipient for wbForm admin notification emails when a form's own Recipient field is empty."|t('webblocks'),
    value:        settings.adminEmail,
    errors:       settings.getErrors('adminEmail')
}) }}

{{ forms.textField({
    label:        "Comment Notification Email"|t('webblocks'),
    id:           'commentNotificationEmail',
    name:         'commentNotificationEmail',
    type:         'email',
    instructions: "When set, an email is sent to this address every time a new comment is submitted and is awaiting moderation."|t('webblocks'),
    value:        settings.commentNotificationEmail,
    errors:       settings.getErrors('commentNotificationEmail')
}) }}

<h2>{{ "SEO"|t('webblocks') }}</h2>

{{ forms.textField({
    label:        "Page Title Format"|t('webblocks'),
    id:           'seoTitleFormat',
    name:         'seoTitleFormat',
    instructions: "Format for the <title> tag when wbSeoTitle is empty. Use {title} and {siteName} as placeholders. Example: {title} — {siteName}"|t('webblocks'),
    value:        settings.seoTitleFormat,
    errors:       settings.getErrors('seoTitleFormat')
}) }}
