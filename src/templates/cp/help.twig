{% extends "_layouts/cp" %}

{% set title = "WebBlocks — " ~ "Help"|t('webblocks') %}
{% set selectedSubnavItem = "help" %}

{% block content %}
<div class="readable" style="max-width: 860px;">

    {# ── Project title ─────────────────────────────────────────────────────── #}
    <h1 style="margin-bottom: 0.25rem;">Fklavyenet WebBlocks</h1>
    <p class="light" style="margin-top: 0; margin-bottom: 2rem;">CraftCMS Plugin</p>

    {# ── Intro ─────────────────────────────────────────────────────────────── #}
    <p class="light" style="font-size:1.1em; margin-bottom: 2rem;">
        {{ "WebBlocks is a portable website-building toolkit for Craft CMS 5. Install it, run the seeder, and get a fully working multi-language business site — complete with pages, blog, forms, SEO, cookie consent, and a colour theme system — in minutes."|t('webblocks') }}
    </p>

    {# ── Quick-start ───────────────────────────────────────────────────────── #}
    <h2>{{ "Quick Start"|t('webblocks') }}</h2>
    <ol>
        <li>{{ "Install the plugin via the Plugin Store or Composer."|t('webblocks') }}</li>
        <li>{{ "Run the seed command from your project root:"|t('webblocks') }}<br>
            <code>php craft webblocks/seed</code></li>
        <li>{{ "Visit %globals% to set the site name, navbar, footer links, and colour theme."|t('webblocks', { '%globals%': '<strong>Globals → Site Config</strong>' })|raw }}</li>
        <li>{{ "Edit, duplicate, or delete the seeded entries in %entries% as needed."|t('webblocks', { '%entries%': '<strong>Entries</strong>' })|raw }}</li>
    </ol>

    {# ── Content blocks ────────────────────────────────────────────────────── #}
    <h2>{{ "Content Blocks (%field% matrix)"|t('webblocks', { '%field%': '<code>wbBlocks</code>' })|raw }}</h2>
    <p>{{ "Every page uses a %field% matrix field. Add, remove, and reorder blocks freely."|t('webblocks', { '%field%': '<code>wbBlocks</code>' })|raw }}</p>

    <table class="data fullwidth">
        <thead>
            <tr><th>{{ "Block"|t('webblocks') }}</th><th>{{ "What it renders"|t('webblocks') }}</th></tr>
        </thead>
        <tbody>
            <tr><td><code>wbHero</code></td><td>{{ "Full-width hero banner with optional overlay, headline, text, and CTA button."|t('webblocks') }}</td></tr>
            <tr><td><code>wbFullscreenImage</code></td><td>{{ "Auto-playing fullscreen slider with dot pagination and caption alignment controls."|t('webblocks') }}</td></tr>
            <tr><td><code>wbCarousel</code></td><td>{{ "Bootstrap carousel with optional captions and frosted-glass overlay."|t('webblocks') }}</td></tr>
            <tr><td><code>wbGallery</code></td><td>{{ "Masonry photo gallery with a built-in lightbox."|t('webblocks') }}</td></tr>
            <tr><td><code>wbCard</code></td><td>{{ "Bootstrap card grid — title, image, text, optional link button."|t('webblocks') }}</td></tr>
            <tr><td><code>wbLeftRight</code></td><td>{{ "Two-column image + text layout with swappable sides."|t('webblocks') }}</td></tr>
            <tr><td><code>wbColumns</code></td><td>{{ "2/3/4-column layout; each column holds its own full %field% stack (recursive nesting)."|t('webblocks', { '%field%': '<code>wbBlocks</code>' })|raw }}</td></tr>
            <tr><td><code>wbTextBlock</code></td><td>{{ "Rich-text prose with optional heading."|t('webblocks') }}</td></tr>
            <tr><td><code>wbHeading</code></td><td>{{ "Standalone heading (h1–h6) with alignment and colour variant."|t('webblocks') }}</td></tr>
            <tr><td><code>wbCallToAction</code></td><td>{{ "Centred CTA section with heading, text, and button."|t('webblocks') }}</td></tr>
            <tr><td><code>wbForm</code></td><td>{{ "Contact/enquiry form — stores submissions, sends admin email, optional visitor confirmation email."|t('webblocks') }}</td></tr>
            <tr><td><code>wbAccordion</code></td><td>{{ "Bootstrap accordion / FAQ block."|t('webblocks') }}</td></tr>
            <tr><td><code>wbTabs</code></td><td>{{ "Bootstrap tabbed content panels."|t('webblocks') }}</td></tr>
            <tr><td><code>wbTable</code></td><td>{{ "Data table with configurable column headers."|t('webblocks') }}</td></tr>
            <tr><td><code>wbListGroup</code></td><td>{{ "Bootstrap list group — plain, linked, or with badges."|t('webblocks') }}</td></tr>
            <tr><td><code>wbVideoEmbed</code></td><td>{{ "Responsive YouTube / Vimeo embed."|t('webblocks') }}</td></tr>
            <tr><td><code>wbContactDetails</code></td><td>{{ "Address, phone, email, and map embed."|t('webblocks') }}</td></tr>
            <tr><td><code>wbAlert</code></td><td>{{ "Bootstrap alert box — dismissible, with theme-aware default colour."|t('webblocks') }}</td></tr>
            <tr><td><code>wbBadge</code></td><td>{{ "Inline Bootstrap badge — pill option, theme-aware default colour."|t('webblocks') }}</td></tr>
            <tr><td><code>wbButtonGroup</code></td><td>{{ "Horizontal or vertical Bootstrap button group."|t('webblocks') }}</td></tr>
            <tr><td><code>wbModal</code></td><td>{{ "Bootstrap modal dialog triggered by a button."|t('webblocks') }}</td></tr>
            <tr><td><code>wbOffcanvas</code></td><td>{{ "Bootstrap offcanvas panel (drawer) with nested blocks."|t('webblocks') }}</td></tr>
            <tr><td><code>wbPopover</code></td><td>{{ "Bootstrap popover tooltip on a button."|t('webblocks') }}</td></tr>
            <tr><td><code>wbProgressBar</code></td><td>{{ "Bootstrap progress bar with label and colour variant."|t('webblocks') }}</td></tr>
            <tr><td><code>wbSpinner</code></td><td>{{ "Bootstrap loading spinner."|t('webblocks') }}</td></tr>
            <tr><td><code>wbToast</code></td><td>{{ "Bootstrap toast notification (always visible, no JS trigger required)."|t('webblocks') }}</td></tr>
            <tr><td><code>wbPagination</code></td><td>{{ "Bootstrap pagination demo block."|t('webblocks') }}</td></tr>
            <tr><td><code>wbNavbar</code></td><td>{{ "Sticky top navigation bar — auto-populated from entries marked 'Show in nav'."|t('webblocks') }}</td></tr>
            <tr><td><code>wbSpacing</code></td><td>{{ "Vertical whitespace spacer."|t('webblocks') }}</td></tr>
        </tbody>
    </table>

    {# ── Global sets ───────────────────────────────────────────────────────── #}
    <h2>{{ "Global Sets"|t('webblocks') }}</h2>

    <h3><code>wbSiteConfig</code></h3>
    <p>{{ "Master configuration for the site: navbar block, footer block, colour mode (light/dark/auto), and colour theme."|t('webblocks') }}</p>
    <table class="data fullwidth">
        <thead><tr><th>{{ "Field"|t('webblocks') }}</th><th>{{ "Purpose"|t('webblocks') }}</th></tr></thead>
        <tbody>
            <tr><td><code>wbColorMode</code></td><td>{{ "Bootstrap colour mode — %light%, %dark%, or %auto% (follows OS preference)."|t('webblocks', { '%light%': '<code>light</code>', '%dark%': '<code>dark</code>', '%auto%': '<code>auto</code>' })|raw }}</td></tr>
            <tr><td><code>wbColorTheme</code></td><td>{{ "Colour theme — selects a Bootswatch theme. WebBlocks loads the matching CSS from CDN automatically."|t('webblocks') }}</td></tr>
            <tr><td><code>wbSiteNavbar</code></td><td>{{ "A single wbNavbar block used site-wide."|t('webblocks') }}</td></tr>
            <tr><td><code>wbSiteFooter</code></td><td>{{ "A single footer block used site-wide."|t('webblocks') }}</td></tr>
        </tbody>
    </table>

    <h3><code>wbCookieSettings</code></h3>
    <p>{{ "Controls the cookie consent banner. Enable the banner, set the title, body text, and privacy URL. Four categories: %necessary% (always on), Analytics, Marketing, Preferences. Consent is stored in %storage% as %key%; the %obj% object is published for third-party scripts."|t('webblocks', {
        '%necessary%': '<strong>' ~ "Necessary"|t('webblocks') ~ '</strong>',
        '%storage%': '<code>localStorage</code>',
        '%key%': '<code>wb_cookie_consent</code>',
        '%obj%': '<code>window.wbCookieConsent</code>'
    })|raw }}</p>

    {# ── Sections ──────────────────────────────────────────────────────────── #}
    <h2>{{ "Sections & Entry Types"|t('webblocks') }}</h2>
    <table class="data fullwidth">
        <thead><tr><th>{{ "Section"|t('webblocks') }}</th><th>{{ "Type"|t('webblocks') }}</th><th>{{ "Purpose"|t('webblocks') }}</th></tr></thead>
        <tbody>
            <tr><td><code>wbHome</code></td><td>Single</td><td>{{ "Homepage — full wbBlocks stack."|t('webblocks') }}</td></tr>
            <tr><td><code>wbPage</code></td><td>Structure</td><td>{{ "General-purpose pages with wbBlocks."|t('webblocks') }}</td></tr>
            <tr><td><code>wbAbout</code></td><td>Structure</td><td>{{ "About / team pages."|t('webblocks') }}</td></tr>
            <tr><td><code>wbServices</code></td><td>Structure</td><td>{{ "Services / products pages."|t('webblocks') }}</td></tr>
            <tr><td><code>wbBlogIndex</code></td><td>Single</td><td>{{ "Blog listing page with pagination."|t('webblocks') }}</td></tr>
            <tr><td><code>wbBlog</code></td><td>Channel</td><td>{{ "Blog posts — featured image, categories, tags, comments."|t('webblocks') }}</td></tr>
            <tr><td><code>wbComments</code></td><td>Channel</td><td>{{ "Blog comments (pending by default). Approve / Reject via CP element actions or the inline toggle on the edit page."|t('webblocks') }}</td></tr>
            <tr><td><code>wbContact</code></td><td>Single</td><td>{{ "Contact page with a wbForm block."|t('webblocks') }}</td></tr>
            <tr><td><code>wbSubmissions</code></td><td>Channel</td><td>{{ "Stores every form submission. Manage status (Unread / Read / Archived) via CP element actions."|t('webblocks') }}</td></tr>
            <tr><td><code>wbSearch</code></td><td>Single</td><td>{{ "Site search — uses craft.entries.search()."|t('webblocks') }}</td></tr>
            <tr><td><code>wbReferences</code></td><td>Channel</td><td>{{ "Client logos / references for a references block."|t('webblocks') }}</td></tr>
        </tbody>
    </table>

    {# ── Forms ─────────────────────────────────────────────────────────────── #}
    <h2>{{ "Forms & Submissions"|t('webblocks') }}</h2>
    <ul>
        <li>{{ "Add a wbForm block to any page. Fields are built in the CP — text, email, phone, textarea, select, checkbox, radio."|t('webblocks') }}</li>
        <li>{{ "Each submission is stored in %path% with the submitted data, originating form reference, and visitor email."|t('webblocks', { '%path%': '<strong>Entries → Submissions</strong>' })|raw }}</li>
        <li>{{ "Admin notification email is sent immediately (Craft mail queue). Only fields with %toggle% toggled on are included."|t('webblocks', { '%toggle%': '<strong>' ~ "Include in admin email"|t('webblocks') ~ '</strong>' })|raw }}</li>
        <li>{{ "Visitor confirmation email is optional — enable it per form and set a subject and body template. Use %placeholder% placeholders in the body."|t('webblocks', { '%placeholder%': '<code>{FieldLabel}</code>' })|raw }}</li>
        <li>{{ "Honeypot spam protection is built in."|t('webblocks') }}</li>
        <li>{{ "To enable Google reCAPTCHA, add your site and secret keys in %path%."|t('webblocks', { '%path%': '<strong>Settings → Plugins → WebBlocks</strong>' })|raw }}</li>
    </ul>

    {# ── Blog comments ─────────────────────────────────────────────────────── #}
    <h2>{{ "Blog Comments"|t('webblocks') }}</h2>
    <ul>
        <li>{{ "Comments are submitted via the front end and stored in %path% with %status% (pending)."|t('webblocks', { '%path%': '<strong>Entries → Comments</strong>', '%status%': '<code>enabled = false</code>' })|raw }}</li>
        <li>{{ "Approve or reject in bulk from the index using the element action menu, or use the %toggle% lightswitch on the individual comment edit page."|t('webblocks', { '%toggle%': '<strong>' ~ "Approved"|t('webblocks') ~ '</strong>' })|raw }}</li>
        <li>{{ "Only approved comments appear on the front end."|t('webblocks') }}</li>
    </ul>

    {# ── SEO ───────────────────────────────────────────────────────────────── #}
    <h2>{{ "SEO"|t('webblocks') }}</h2>
    <p>{{ "Every entry type that powers a page has %seoTitle% and %seoDesc% fields. Leave them blank to fall back to the entry title and site name. The %head% partial outputs the correct %title%, %desc%, and Open Graph tags automatically."|t('webblocks', {
        '%seoTitle%': '<code>wbSeoTitle</code>',
        '%seoDesc%': '<code>wbSeoDescription</code>',
        '%head%': '<code>&lt;head&gt;</code>',
        '%title%': '<code>&lt;title&gt;</code>',
        '%desc%': '<code>&lt;meta name="description"&gt;</code>'
    })|raw }}</p>

    {# ── Accent colours ─────────────────────────────────────────────────────── #}
    <h2>{{ "Accent Colours"|t('webblocks') }}</h2>
    <p>{{ "Set the brand colour in %path% using the %data-accent% attribute on %html%. WebBlocks ships 8 accent palettes — every component (buttons, cards, navbar, badges, alerts, forms) inherits the colour automatically. No rebuild required."|t('webblocks', {
        '%path%': '<strong>Globals → Site Config → Accent Colour</strong>',
        '%data-accent%': '<code>data-accent</code>',
        '%html%': '<code>&lt;html&gt;</code>'
    })|raw }}</p>
    <table class="data fullwidth">
        <thead><tr><th>{{ "Accent"|t('webblocks') }}</th><th>{{ "Character"|t('webblocks') }}</th></tr></thead>
        <tbody>
            <tr><td>ocean</td><td>{{ "Deep teal-blue. Professional, trustworthy, calming."|t('webblocks') }}</td></tr>
            <tr><td>forest</td><td>{{ "Rich green. Natural, organic, fresh."|t('webblocks') }}</td></tr>
            <tr><td>sunset</td><td>{{ "Warm orange-amber. Energetic, friendly, inviting."|t('webblocks') }}</td></tr>
            <tr><td>royal</td><td>{{ "Deep purple-blue. Elegant, premium, authoritative."|t('webblocks') }}</td></tr>
            <tr><td>mint</td><td>{{ "Soft mint-green. Modern, clean, approachable."|t('webblocks') }}</td></tr>
            <tr><td>amber</td><td>{{ "Golden amber. Warm, confident, bold."|t('webblocks') }}</td></tr>
            <tr><td>rose</td><td>{{ "Dusty rose. Sophisticated, stylish, refined."|t('webblocks') }}</td></tr>
            <tr><td>slate-fire</td><td>{{ "Slate-grey with fire-orange accents. Contemporary, edgy, distinctive."|t('webblocks') }}</td></tr>
        </tbody>
    </table>

    {# ── Style presets ─────────────────────────────────────────────────────── #}
    <h2>{{ "Style Presets"|t('webblocks') }}</h2>
    <p>{{ "Set the component style package in %path% using the %data-preset% attribute on %html%. Combine with any accent colour for complete visual control."|t('webblocks', {
        '%path%': '<strong>Globals → Site Config → Style Preset</strong>',
        '%data-preset%': '<code>data-preset</code>',
        '%html%': '<code>&lt;html&gt;</code>'
    })|raw }}</p>
    <table class="data fullwidth">
        <thead><tr><th>{{ "Preset"|t('webblocks') }}</th><th>{{ "Character"|t('webblocks') }}</th></tr></thead>
        <tbody>
            <tr><td>modern</td><td>{{ "Clean lines, subtle shadows, contemporary feel."|t('webblocks') }}</td></tr>
            <tr><td>minimal</td><td>{{ "Reduced styling, maximum whitespace, stripped-back aesthetic."|t('webblocks') }}</td></tr>
            <tr><td>rounded</td><td>{{ "Fully rounded corners on all components. Soft and approachable."|t('webblocks') }}</td></tr>
            <tr><td>bold</td><td>{{ "Heavy borders, strong contrast, impactful presence."|t('webblocks') }}</td></tr>
            <tr><td>editorial</td><td>{{ "Serif headings, generous spacing, magazine-style layouts."|t('webblocks') }}</td></tr>
        </tbody>
    </table>

    {# ── Colour mode ───────────────────────────────────────────────────────── #}
    <h2>{{ "Colour Mode"|t('webblocks') }}</h2>
    <p>{{ "WebBlocks supports light, dark, and auto (system preference) colour modes. The mode toggle in the navbar calls %applyMode% which sets %data-mode% on %html% and stores the preference in localStorage."|t('webblocks', {
        '%applyMode%': '<code>WBColorMode.applyMode()</code>',
        '%data-mode%': '<code>data-mode</code>',
        '%html%': '<code>&lt;html&gt;</code>'
    })|raw }}</p>

    <p>{{ "To apply custom styles on top of any preset, use %cssUrl% (external stylesheet) or %css% (inline rules injected into %head%)."|t('webblocks', {
        '%cssUrl%': '<strong>Globals → Site Config → Custom CSS URL</strong>',
        '%css%': '<strong>Custom CSS</strong>',
        '%head%': '<code>&lt;head&gt;</code>'
    })|raw }}</p>

    {# ── Multi-language ────────────────────────────────────────────────────── #}
    <h2>{{ "Multi-language"|t('webblocks') }}</h2>
    <p>{{ "WebBlocks seeds content in English, Turkish, and German when those sites exist in Craft. Add more sites in %path% and translate entries normally via the site switcher on each entry's edit page."|t('webblocks', { '%path%': '<strong>Settings → Sites</strong>' })|raw }}</p>

    {# ── Wipe & reseed ─────────────────────────────────────────────────────── #}
    <h2>{{ "Wipe & Reseed"|t('webblocks') }}</h2>
    <p>{{ "To reset all demo content and reinstall the full schema:"|t('webblocks') }}</p>
    <pre>php craft webblocks/wipe/all</pre>
    <p class="warning">{{ "This is destructive — all existing WebBlocks content will be permanently deleted."|t('webblocks') }}</p>

    {# ── Plugin settings ──────────────────────────────────────────────────── #}
    <h2>{{ "Plugin Settings"|t('webblocks') }}</h2>
    <p>{{ "Configure WebBlocks at %path%."|t('webblocks', { '%path%': '<strong>Settings → Plugins → WebBlocks</strong>' })|raw }}</p>
    <table class="data fullwidth">
        <thead><tr><th>{{ "Setting"|t('webblocks') }}</th><th>{{ "Purpose"|t('webblocks') }}</th></tr></thead>
        <tbody>
            <tr><td>{{ "Default Admin Email"|t('webblocks') }}</td><td>{{ "Fallback recipient for wbForm admin notifications when a form's own Recipient field is empty."|t('webblocks') }}</td></tr>
            <tr><td>{{ "Comment Notification Email"|t('webblocks') }}</td><td>{{ "Receives an email whenever a new blog comment is submitted and awaits moderation."|t('webblocks') }}</td></tr>
            <tr><td>{{ "Page Title Format"|t('webblocks') }}</td><td>{{ "Controls the %title% tag format when wbSeoTitle is blank. Supports {title} and {siteName} placeholders."|t('webblocks', { '%title%': '<code>&lt;title&gt;</code>' })|raw }}</td></tr>
            <tr><td>{{ "Seed Languages"|t('webblocks') }}</td><td>{{ "Which languages to seed on the next wipe + seed cycle (English is always included)."|t('webblocks') }}</td></tr>
            <tr><td>{{ "GA4 Measurement ID"|t('webblocks') }}</td><td>{{ "Google Analytics 4 ID (e.g. G-XXXXXXXXXX). Leave blank to disable."|t('webblocks') }}</td></tr>
            <tr><td>{{ "Matomo URL / Site ID"|t('webblocks') }}</td><td>{{ "Matomo instance URL and site ID. Both required to activate tracking."|t('webblocks') }}</td></tr>
        </tbody>
    </table>

    {# ── Component versioning ──────────────────────────────────────────────── #}
    <h2>{{ "Component Versioning"|t('webblocks') }}</h2>
    <p>{{ "WebBlocks tracks the installed version of every component (field, entry type, matrix field) in the %table% database table. Use the console commands below to audit and migrate components when the plugin is updated."|t('webblocks', { '%table%': '<code>webblocks_component_versions</code>' })|raw }}</p>
    <table class="data fullwidth">
        <thead><tr><th>{{ "Command"|t('webblocks') }}</th><th>{{ "What it does"|t('webblocks') }}</th></tr></thead>
        <tbody>
            <tr><td><code>webblocks/components/diff</code></td><td>{{ "Full diff report — JSON version vs installed DB state."|t('webblocks') }}</td></tr>
            <tr><td><code>webblocks/components/check</code></td><td>{{ "Exit 0 if everything is up to date, exit 1 if action is needed (CI-friendly)."|t('webblocks') }}</td></tr>
            <tr><td><code>webblocks/components/dry-run</code></td><td>{{ "Preview what a migration run would do without making any changes."|t('webblocks') }}</td></tr>
            <tr><td><code>webblocks/components/migrate</code></td><td>{{ "Apply all pending component migrations."|t('webblocks') }}</td></tr>
            <tr><td><code>webblocks/components/cleanup-deprecated</code></td><td>{{ "List deprecated fields. Add --force to permanently delete them."|t('webblocks') }}</td></tr>
        </tbody>
    </table>
    <p>{{ "The %link% in the CP sidebar shows a live health summary — pending migrations, deprecated fields, and component version mismatches."|t('webblocks', { '%link%': '<strong>' ~ "Component Health"|t('webblocks') ~ '</strong>' })|raw }}</p>

    {# ── Requirements ──────────────────────────────────────────────────────── #}
    <h2>{{ "Requirements"|t('webblocks') }}</h2>
    <ul>
        <li>Craft CMS 5.x</li>
        <li>{{ "CKEditor plugin (installed automatically as a dependency)"|t('webblocks') }}</li>
        <li>{{ "Bootstrap 5.3 CDN (loaded from the default layout template — no npm required)"|t('webblocks') }}</li>
    </ul>

</div>
{% endblock %}
