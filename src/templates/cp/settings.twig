{% extends "_layouts/cp" %}

{% set title = "WebBlocks — " ~ "Settings"|t('app') %}
{% set selectedSubnavItem = "settings" %}

{% block content %}
<div class="readable">
    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('plugins/save-plugin-settings') }}
        {{ hiddenInput('pluginHandle', 'webblocks') }}
        {{ redirectInput('webblocks/settings') }}

        {% import "_includes/forms" as forms %}

        <h2>{{ "Email"|t('app') }}</h2>

        {{ forms.textField({
            label:        "Default Admin Email"|t('webblocks'),
            id:           'adminEmail',
            name:         'settings[adminEmail]',
            type:         'email',
            instructions: "Fallback recipient for wbForm admin notification emails when a form's own Recipient field is empty."|t('webblocks'),
            value:        settings.adminEmail,
            errors:       settings.getErrors('adminEmail')
        }) }}

        <div class="buttons">
            <button type="submit" class="btn submit">{{ "Save"|t('app') }}</button>
        </div>
    </form>
</div>
{% endblock %}
