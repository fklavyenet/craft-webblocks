<div class="wb-block wb-accordion wb-mb-4" id="accordion-{{ item.id|default(loop.index) }}">
    {% if item.wbAccordionItems %}
        {% for accordionItem in item.wbAccordionItems.all() %}
            <div class="wb-accordion-item">
                <button class="wb-accordion-trigger" type="button"
                        data-wb-accordion
                        data-wb-target="#collapse-{{ accordionItem.id }}"
                        data-wb-parent="#accordion-{{ item.id|default(loop.index) }}"
                        aria-expanded="false"
                        aria-controls="collapse-{{ accordionItem.id }}">
                    {{ accordionItem.wbTitle }}
                </button>
                <div id="collapse-{{ accordionItem.id }}" class="wb-accordion-content" hidden>
                    <div class="wb-accordion-body">
                        {{ accordionItem.wbText }}
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endif %}
</div>
