{% set variant = item.wbBadgeType.value ?? item.wbBadgeType ?? '' %}
{% set pill = item.wbBadgePill ?? false %}
<div class="wb-block wb-mb-4">
    {% if item.wbTitle %}<p style="margin-bottom:0.25rem;font-weight:600;">{{ item.wbTitle }}</p>{% endif %}
    <span class="wb-badge{% if variant %} wb-badge-{{ variant }}{% endif %}{% if pill %} wb-badge-pill{% endif %}">
        {{ item.wbText ?? '' }}
    </span>
</div>
