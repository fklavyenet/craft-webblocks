{# wbBreadcrumb — WebBlocks UI Kit breadcrumb built from entry ancestor chain #}
{% set _bcEntry = entry ?? null %}
{% if _bcEntry %}
    {% set _ancestors = _bcEntry.ancestors.all() %}
    <nav aria-label="breadcrumb" class="wb-breadcrumb">
        <ol class="wb-breadcrumb-list">
            <li class="wb-breadcrumb-item">
                <a href="{{ siteUrl }}">{{ 'Home'|t }}</a>
            </li>
            {% for _ancestor in _ancestors %}
                <li class="wb-breadcrumb-item">
                    <a href="{{ _ancestor.url }}">{{ _ancestor.title }}</a>
                </li>
            {% endfor %}
            <li class="wb-breadcrumb-item is-active" aria-current="page">
                {{ _bcEntry.title }}
            </li>
        </ol>
    </nav>
{% endif %}
