{% set hasBorder   = item.wbBorder ?? false %}
{% set borderColor = item.wbBorderColor.value ?? item.wbBorderColor ?? '' %}
{% set rounded     = item.wbRounded.value ?? item.wbRounded ?? '' %}
{% set padding     = item.wbPadding.value ?? item.wbPadding ?? '' %}
{% set titlePos    = item.wbTitlePosition.value ?? item.wbTitlePosition ?? 'outside' %}
{% set extraClasses = '' %}
{% if hasBorder %}{% set extraClasses = extraClasses ~ ' wb-border' %}{% endif %}
{% if hasBorder and borderColor %}{% set extraClasses = extraClasses ~ ' wb-border-' ~ borderColor %}{% endif %}
{% if rounded %}{% set extraClasses = extraClasses ~ ' ' ~ rounded %}{% endif %}
{% if padding %}{% set extraClasses = extraClasses ~ ' ' ~ padding %}{% endif %}

{% if item.wbTitle and titlePos == 'outside' %}
    <h2>{{ item.wbTitle }}</h2>
{% endif %}
<section class="wb-block wb-mb-4{{ extraClasses }}" style="{% if item.wbBackgroundColor %}background-color: {{ item.wbBackgroundColor }}; color: #fff; padding: 2rem;{% endif %}">
    <div style="display:flex;flex-direction:column;align-items:flex-start;gap:1rem;">
        {% if item.wbTitle and titlePos == 'inside' %}
            <h2>{{ item.wbTitle }}</h2>
        {% endif %}
        {% if item.wbText %}
            <p style="color:{% if item.wbBackgroundColor %}#fff;{% else %}{% endif %}">{{ item.wbText }}</p>
        {% endif %}
        {% if item.wbButtonUrl and item.wbButtonLabel %}
            {% set _ctaUrl = item.wbButtonUrl %}
            {% set _ctaUrl = (_ctaUrl|lower starts with 'javascript:' or _ctaUrl|lower starts with 'data:') ? '#' : _ctaUrl %}
            <a href="{{ _ctaUrl }}" class="wb-btn{% if item.wbButtonColor %} wb-btn-primary{% else %} wb-btn-primary{% endif %}">
                {{ item.wbButtonLabel }}
            </a>
        {% endif %}
    </div>
</section>
