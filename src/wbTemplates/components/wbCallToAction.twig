{% set hasBorder   = item.wbBorder ?? false %}
{% set borderColor = item.wbBorderColor.value ?? item.wbBorderColor ?? '' %}
{% set rounded     = item.wbRounded.value ?? item.wbRounded ?? '' %}
{% set padding     = item.wbPadding.value ?? item.wbPadding ?? '' %}
{% set titlePos    = item.wbTitlePosition.value ?? item.wbTitlePosition ?? 'outside' %}
{% set extraClasses = '' %}
{% if hasBorder %}{% set extraClasses = extraClasses ~ ' border' %}{% endif %}
{% if hasBorder and borderColor %}{% set extraClasses = extraClasses ~ ' border-' ~ borderColor %}{% endif %}
{% if rounded %}{% set extraClasses = extraClasses ~ ' ' ~ rounded %}{% endif %}
{% if padding %}{% set extraClasses = extraClasses ~ ' ' ~ padding %}{% endif %}

{% if item.wbTitle and titlePos == 'outside' %}
    <h2>{{ item.wbTitle }}</h2>
{% endif %}
<section class="wb-block cta mb-4{{ extraClasses }}" style="{% if item.wbBackgroundColor %}background-color: {{ item.wbBackgroundColor }}; color: #fff;{% endif %}">
    <div class="cta-content">
        {% if item.wbTitle and titlePos == 'inside' %}
            <h2>{{ item.wbTitle }}</h2>
        {% endif %}
        {% if item.wbText %}
            <p>{{ item.wbText }}</p>
        {% endif %}
        {% if item.wbButtonUrl and item.wbButtonLabel %}
            {% set _ctaUrl = item.wbButtonUrl %}
            {% set _ctaUrl = (_ctaUrl|lower starts with 'javascript:' or _ctaUrl|lower starts with 'data:') ? '#' : _ctaUrl %}
            <a href="{{ _ctaUrl }}" class="btn{% if not item.wbButtonColor %} wb-theme-btn btn-primary{% endif %}" style="{% if item.wbButtonColor %}background-color: {{ item.wbButtonColor }}; border-color: {{ item.wbButtonColor }}; color: #333;{% endif %}">
                {{ item.wbButtonLabel }}
            </a>
        {% endif %}
    </div>
</section>
