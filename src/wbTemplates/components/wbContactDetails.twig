{% set hasBorder  = item.wbBorder ?? false %}
{% set borderColor = item.wbBorderColor.value ?? item.wbBorderColor ?? '' %}
{% set roundedVal  = item.wbRounded.value ?? item.wbRounded ?? '' %}
{% set paddingVal  = item.wbPadding.value ?? item.wbPadding ?? '' %}
{% set titlePos    = item.wbTitlePosition.value ?? item.wbTitlePosition ?? 'outside' %}
{% set roundedMap = {'rounded-1': 'wb-rounded-sm', 'rounded-2': 'wb-rounded-md', 'rounded-3': 'wb-rounded-lg', 'rounded-4': 'wb-rounded-xl', 'rounded-5': 'wb-rounded-full'} %}
{% set paddingMap = {'p-2': 'wb-p-2', 'p-3': 'wb-p-3', 'p-4': 'wb-p-4', 'p-5': 'wb-p-5'} %}
{% set roundedClass = roundedVal ? (roundedMap[roundedVal] ?? roundedVal) : '' %}
{% set paddingClass = paddingVal ? (paddingMap[paddingVal] ?? paddingVal) : '' %}
{% set extraClasses = '' %}
{% if hasBorder %}{% set extraClasses = extraClasses ~ ' wb-border' %}{% endif %}
{% if hasBorder and borderColor %}{% set extraClasses = extraClasses ~ ' wb-border-' ~ borderColor %}{% endif %}
{% if roundedClass %}{% set extraClasses = extraClasses ~ ' ' ~ roundedClass %}{% endif %}
{% if paddingClass %}{% set extraClasses = extraClasses ~ ' ' ~ paddingClass %}{% endif %}

{% if item.wbTitle and titlePos == 'outside' %}
    <h2>{{ item.wbTitle }}</h2>
{% endif %}
<section class="wb-block contact-details wb-mb-4{{ extraClasses }}" style="{% if item.wbBackgroundColor %}background-color: {{ item.wbBackgroundColor }};{% endif %}">
    {% if item.wbTitle and titlePos == 'inside' %}
        <h2>{{ item.wbTitle }}</h2>
    {% endif %}
    <div class="wb-gap-3">
        {% if item.wbPhone %}
            <div>
                <strong>Phone:</strong>
                <a href="tel:{{ item.wbPhone|replace({' ': '', '-': ''}) }}">{{ item.wbPhone }}</a>
            </div>
        {% endif %}
        {% if item.wbEmail %}
            <div>
                <strong>Email:</strong>
                <a href="mailto:{{ item.wbEmail }}">{{ item.wbEmail }}</a>
            </div>
        {% endif %}
        {% if item.wbAddress %}
            <div>
                <strong>Address:</strong>
                <p>{{ item.wbAddress }}</p>
            </div>
        {% endif %}
    </div>
</section>
