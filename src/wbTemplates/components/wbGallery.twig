{% set cols = item.wbColumnsCount.value ?? '3' %}
{#
    On mobile (<576px) always show 1 column.
    On sm+ show the chosen column count.
    We embed a small <style> block keyed to this block's ID so multiple galleries
    on the same page each get the right column count.
#}
{% set blockId = 'wb-gallery-' ~ item.id %}

<section class="wb-block wb-py-4">
    {% if item.wbTitle is defined and item.wbTitle %}
        <h2 class="wb-mb-4">{{ item.wbTitle }}</h2>
    {% endif %}

    <style>
        #{{ blockId }} { --wb-gallery-cols: 1; gap: 1rem; }
        @media (min-width: 576px) { #{{ blockId }} { --wb-gallery-cols: {{ cols }}; } }
    </style>

    <div
        id="{{ blockId }}"
        style="display: grid; grid-template-columns: repeat(var(--wb-gallery-cols, {{ cols }}), 1fr); gap: 1rem;"
        data-wb-masonry
    >
        {% for galleryItem in item.wbGalleryItems.all() %}
            {% set img = galleryItem.wbImage.one() ?? null %}
            {% if img %}
                <div>
                    <a href="{{ img.getUrl('wbGalleryFull') }}"
                       data-fancybox="gallery-{{ item.id }}"
                       data-caption="{{ galleryItem.wbCaption ?? img.title }}">
                        <img src="{{ img.getUrl('wbGalleryThumb') }}"
                             alt="{{ img.alt ?: (galleryItem.wbCaption ?? img.title) }}"
                             style="display:block;width:100%;height:auto;border-radius:var(--wb-r-md,0.375rem);cursor:zoom-in;">
                    </a>
                    {% if galleryItem.wbCaption ?? '' %}
                        <p style="font-size:0.875rem;color:var(--wb-muted);margin-top:0.5rem;margin-bottom:0;">{{ galleryItem.wbCaption }}</p>
                    {% endif %}
                </div>
            {% endif %}
        {% endfor %}
    </div>
</section>
