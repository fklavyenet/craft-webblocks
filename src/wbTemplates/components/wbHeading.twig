{% set tag = item.wbHeadingLevel.value ?? 'h2' %}
{% set tag = tag in ['h1','h2','h3','h4','h5','h6'] ? tag : 'h2' %}
{% set align = item.wbHeadingAlign.value ?? 'start' %}
{% set alignMap = { 'start': 'left', 'center': 'center', 'end': 'right' } %}
{% set alignClass = alignMap[align] ?? 'left' %}
<{{ tag }} class="wb-heading wb-mb-4 wb-text-{{ alignClass }}"{% if item.wbTextColor %} style="color: {{ item.wbTextColor }};"{% endif %}>
    {{- item.wbTitle -}}
</{{ tag }}>
