{% for row in item.wbLeftRightItems.all() %}
    {% set image = row.wbImage.one() %}
    {% set isEven = loop.index is even %}

    <div style="display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:0;margin-bottom:2rem;{% if isEven %}direction:rtl;{% endif %}">

        {# Image column #}
        <div style="{% if isEven %}direction:ltr;{% endif %}">
            {% if image %}
                <img src="{{ image.getUrl('wbLeftRight') }}" alt="{{ image.alt ?: image.title }}" style="max-width:100%;height:auto;width:100%;">
            {% else %}
                <div style="background:var(--wb-surface-2);aspect-ratio:16/9;overflow:hidden;"></div>
            {% endif %}
        </div>

        {# Text column #}
        <div style="padding:1.5rem;{% if isEven %}direction:ltr;padding-inline-end:2rem;{% else %}padding-inline-start:2rem;{% endif %}">
            {% if row.wbTitle %}
                <h2>{{ row.wbTitle }}</h2>
            {% endif %}
            {% if row.wbText %}
                <div style="margin-bottom:0.75rem;">{{ row.wbText }}</div>
            {% endif %}
            {% if row.wbButtonLabel and row.wbButtonUrl %}
                <a href="{{ row.wbButtonUrl }}"
                   class="wb-btn wb-btn-primary{% if row.wbButtonSize %} wb-btn-{{ row.wbButtonSize }}{% endif %}"
                   {% if row.wbButtonTarget %}target="{{ row.wbButtonTarget }}"{% endif %}>
                    {{ row.wbButtonLabel }}
                </a>
            {% endif %}
        </div>

    </div>
{% endfor %}
