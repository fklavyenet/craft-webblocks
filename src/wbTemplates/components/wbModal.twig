{# wbModal — WebBlocks UI Kit modal with trigger button #}
{% set _modalId = 'wbModal-' ~ item.id %}
{% set _size = item.wbModalSize.value ?? '' %}
{% set _btnLabel = item.wbButtonLabel ?? item.wbTitle ?? 'Open' %}

<div class="wb-block wb-modal-wrapper">
    {# Trigger button #}
    <button type="button"
            class="wb-btn wb-btn-primary"
            style="{% if item.wbButtonColor %}background-color: {{ item.wbButtonColor }}; border-color: {{ item.wbButtonColor }};{% endif %}"
            data-wb-modal="open"
            data-wb-target="#{{ _modalId }}">
        {{ _btnLabel }}
    </button>

    {# Modal #}
    <div class="wb-modal" id="{{ _modalId }}" role="dialog"
         aria-labelledby="{{ _modalId }}-label" aria-modal="true" hidden>
        <div class="wb-modal-dialog{% if _size %} {{ _size }}{% endif %}">
            <div class="wb-modal-header">
                <h5 class="wb-modal-title" id="{{ _modalId }}-label">{{ item.wbTitle }}</h5>
                <button type="button" class="wb-modal-close" data-wb-modal="close"
                        aria-label="{{ 'Close'|t }}"></button>
            </div>
            {% if item.wbText %}
                <div class="wb-modal-body">
                    {{ item.wbText }}
                </div>
            {% endif %}
            <div class="wb-modal-footer">
                <button type="button" class="wb-btn wb-btn-secondary"
                        data-wb-modal="close">{{ 'Close'|t }}</button>
            </div>
        </div>
    </div>
</div>
