{% set navItems = item.wbNavbarItems.all() %}
{% set navbarId = 'wbNavbar-' ~ item.id %}
{% set logo = item.wbNavbarLogo.one() ?? null %}
{% set showSearch = item.wbNavbarSearch ?? false %}
{% set searchPlaceholder = item.wbNavbarSearchPlaceholder ?? 'Search...' %}

{# Auto-collect entries with wbShowInNav enabled when no manual items are defined #}
{% if not navItems|length %}
    {% set autoNavEntries = craft.entries()
        .wbShowInNav(true)
        .all()
        |sort((a, b) =>
            (a.wbNavOrder ? a.wbNavOrder : 9999) - (b.wbNavOrder ? b.wbNavOrder : 9999)
            ?: (a.level != b.level ? (a.level - b.level) : (a.lft - b.lft))
        ) %}

    {# Also collect any parent entries of opted-in children, so they appear as dropdown labels
       even when the parent itself does not have wbShowInNav enabled. #}
    {% set missingParentIds = [] %}
    {% for navEntry in autoNavEntries %}
        {% if navEntry.level > 1 and navEntry.parent %}
            {% set parentId = navEntry.parent.id %}
            {% set parentAlreadyIncluded = false %}
            {% for e in autoNavEntries %}
                {% if e.id == parentId %}{% set parentAlreadyIncluded = true %}{% endif %}
            {% endfor %}
            {% if not parentAlreadyIncluded and parentId not in missingParentIds %}
                {% set missingParentIds = missingParentIds|merge([parentId]) %}
            {% endif %}
        {% endif %}
    {% endfor %}

    {% if missingParentIds|length %}
        {% set parentEntries = craft.entries().id(missingParentIds).all() %}
        {% set autoNavEntries = autoNavEntries|merge(parentEntries)|sort((a, b) =>
            (a.wbNavOrder ? a.wbNavOrder : 9999) - (b.wbNavOrder ? b.wbNavOrder : 9999)
            ?: (a.level != b.level ? (a.level - b.level) : (a.lft - b.lft))
        ) %}
    {% endif %}
{% endif %}

{# Build a flat nav list: manual items take priority over auto entries #}
{% set hasNav = navItems|length or (autoNavEntries is defined and autoNavEntries|length) %}

{# Resolve the search page URL #}
{% set searchEntry = craft.entries().section('wbSearch').one() %}
{% set searchUrl = searchEntry ? searchEntry.url : '/search' %}

<nav class="wb-block wb-navbar sticky-top navbar navbar-expand-lg">
    <div class="container-fluid">

        {# Brand #}
        <a class="navbar-brand" href="/">
            {% if logo %}
                <img src="{{ logo.url }}" alt="{{ item.wbNavbarBrand ?? logo.alt ?: logo.title }}" height="30" class="d-inline-block align-text-top">
                {% if item.wbNavbarBrand %}
                    {{ item.wbNavbarBrand }}
                {% endif %}
            {% elseif item.wbNavbarBrand %}
                {{ item.wbNavbarBrand }}
            {% endif %}
        </a>

        {# Toggler — shown when either nav items or search are present #}
        {% if hasNav or showSearch %}
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#{{ navbarId }}"
                    aria-controls="{{ navbarId }}"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="{{ navbarId }}">

                {# Nav items — manual mode (wbNavbarItems defined) #}
                {% if navItems|length %}
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        {% for navItem in navItems %}
                            <li class="nav-item">
                                <a class="nav-link"
                                   href="{{ navItem.wbNavItemUrl ?? '#' }}"
                                   {% if navItem.wbNavItemTarget.value == '_blank' %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                    {{ navItem.wbNavItemLabel }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>

                {# Nav items — auto mode (entries with wbShowInNav enabled) #}
                {% elseif autoNavEntries is defined and autoNavEntries|length %}
                    {# Group top-level entries with their direct children for dropdown support #}
                    {% set topLevel = [] %}
                    {% set childrenMap = {} %}
                    {% for navEntry in autoNavEntries %}
                        {% if navEntry.level <= 1 %}
                            {% set topLevel = topLevel|merge([navEntry]) %}
                        {% else %}
                            {% set pKey = 'p' ~ navEntry.parent.id %}
                            {% set siblings = childrenMap[pKey] is defined ? childrenMap[pKey] : [] %}
                            {% set childrenMap = childrenMap|merge({ (pKey): siblings|merge([navEntry]) }) %}
                        {% endif %}
                    {% endfor %}

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        {% for navEntry in topLevel %}
                            {% set children = childrenMap['p' ~ navEntry.id] is defined ? childrenMap['p' ~ navEntry.id] : [] %}
                            {% if children|length %}
                                {# Dropdown for entries with visible children #}
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle"
                                       href="{{ navEntry.url }}"
                                       role="button"
                                       data-bs-toggle="dropdown"
                                       aria-expanded="false">
                                        {{ navEntry.title }}
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <a class="dropdown-item" href="{{ navEntry.url }}">{{ navEntry.title }}</a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        {% for child in children %}
                                            <li>
                                                <a class="dropdown-item" href="{{ child.url }}">{{ child.title }}</a>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </li>
                            {% else %}
                                <li class="nav-item">
                                    <a class="nav-link{% if navEntry.uri == craft.app.request.pathInfo %} active{% endif %}"
                                       href="{{ navEntry.url }}">
                                        {{ navEntry.title }}
                                    </a>
                                </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                {% else %}
                    {# Spacer so search stays right-aligned even with no nav items #}
                    <div class="me-auto"></div>
                {% endif %}

                {# Search form #}
                {% if showSearch %}
                    <form class="d-flex" role="search" method="get" action="{{ searchUrl }}">
                        <input class="form-control me-2"
                               type="search"
                               name="q"
                               value="{{ craft.app.request.getParam('q')|escape }}"
                               placeholder="{{ searchPlaceholder }}"
                               aria-label="{{ searchPlaceholder }}">
                        <button class="btn btn-outline-secondary" type="submit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                            </svg>
                        </button>
                    </form>
                {% endif %}

                {# Language switcher — only shown when more than one site exists #}
                {% set _allSites = craft.app.sites.getAllSites() %}
                {% if _allSites|length > 1 %}
                    {% set _activeLang = currentSite.language|slice(0, 2)|upper %}
                    <div class="dropdown ms-2">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle wb-lang-btn"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false"
                                aria-label="Select language">
                            {{ _activeLang }}
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            {% for _site in _allSites %}
                                {% set _lang = _site.language|slice(0, 2)|upper %}
                                {% set _isActive = (_site.id == currentSite.id) %}
                                <li>
                                    {% if _isActive %}
                                        <span class="dropdown-item active" aria-current="true">{{ _lang }}</span>
                                    {% else %}
                                        {% set _localizedEntry = entry is defined ? craft.entries().id(entry.id).siteId(_site.id).one() : null %}
                                        {% set _localizedUrl = _localizedEntry ? _localizedEntry.url : _site.baseUrl %}
                                        <a class="dropdown-item"
                                           href="{{ _localizedUrl }}"
                                           hreflang="{{ _site.language }}"
                                           lang="{{ _site.language }}">{{ _lang }}</a>
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {# Color mode toggle (light → dark → auto) #}
                <button class="btn border-0 bg-transparent nav-link px-2 wb-color-mode-toggle ms-2"
                        type="button"
                        aria-label="Toggle color mode"
                        title="Toggle color mode">
                    {# Sun icon — shown in light mode #}
                    <svg class="wb-theme-icon wb-theme-icon-light" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6m0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708"/>
                    </svg>
                    {# Moon icon — shown in dark mode #}
                    <svg class="wb-theme-icon wb-theme-icon-dark" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M6 .278a.77.77 0 0 1 .08.858 7.2 7.2 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277q.792-.001 1.533-.16a.79.79 0 0 1 .81.316.73.73 0 0 1-.031.893A8.35 8.35 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.75.75 0 0 1 6 .278"/>
                    </svg>
                    {# Circle-half icon — shown in auto mode #}
                    <svg class="wb-theme-icon wb-theme-icon-auto" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 0 8 1zm0 1A8 8 0 1 1 8 0a8 8 0 0 1 0 16"/>
                    </svg>
                </button>

            </div>
        {% endif %}

    </div>
</nav>

