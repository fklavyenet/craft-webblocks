{# wbOffcanvas — WebBlocks UI Kit drawer panel with trigger button #}
{% set placement  = item.wbOffcanvasPlacement.value ?? item.wbOffcanvasPlacement ?? 'start' %}
{% set backdrop   = item.wbOffcanvasBackdrop ?? true %}
{% set btnLabel   = item.wbButtonLabel ?? 'Open Panel' %}
{% set btnSize    = item.wbButtonSize.value ?? item.wbButtonSize ?? '' %}
{% set oc_id      = 'wbOffcanvas-' ~ item.id %}

<div class="wb-block">
    {# Trigger button #}
    <button type="button"
            class="wb-btn wb-btn-primary{% if btnSize and btnSize != 'md' %} wb-btn-{{ btnSize }}{% endif %}"
            data-wb-toggle="drawer"
            data-wb-target="#{{ oc_id }}"
            aria-controls="{{ oc_id }}">
        {{ btnLabel }}
    </button>

    {# Drawer panel #}
    <div class="wb-drawer wb-drawer-{{ placement }}"
         {% if not backdrop %}data-wb-backdrop="false"{% endif %}
         id="{{ oc_id }}"
         role="dialog"
         aria-labelledby="{{ oc_id }}-label"
         hidden>
        <div class="wb-drawer-header">
            <h5 class="wb-drawer-title" id="{{ oc_id }}-label">{{ item.wbTitle ?? '' }}</h5>
            <button type="button" class="wb-btn-close" data-wb-dismiss="drawer" aria-label="Close"></button>
        </div>
        <div class="wb-drawer-body">
            {% for block in item.wbBlocks.all() %}
                {% set item = block %}
                {% include "wb/components/#{block.type.handle}" ignore missing %}
            {% endfor %}
        </div>
    </div>
</div>
