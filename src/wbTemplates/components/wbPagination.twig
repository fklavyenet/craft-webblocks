{% set pages = item.wbPaginationPages ?? 5 %}
{% set align = item.wbPaginationAlign.value ?? item.wbPaginationAlign ?? 'start' %}
{% set size  = item.wbPaginationSize.value ?? item.wbPaginationSize ?? '' %}
<div class="wb-block wb-mb-4">
    {% if item.wbTitle %}<h5>{{ item.wbTitle }}</h5>{% endif %}
    <nav aria-label="Page navigation">
        <div class="wb-pagination{% if size %} wb-pagination-{{ size }}{% endif %}{% if align == 'center' %} wb-justify-center{% elseif align == 'end' %} wb-justify-end{% endif %}">
            <a href="#" class="wb-page-item wb-page-item-disabled" aria-label="Previous">
                <span aria-hidden="true">&laquo;</span>
            </a>
            {% for p in 1..pages %}
                <a href="#" class="wb-page-item{% if p == 1 %} is-active{% endif %}"{% if p == 1 %} aria-current="page"{% endif %}>{{ p }}</a>
            {% endfor %}
            <a href="#" class="wb-page-item" aria-label="Next">
                <span aria-hidden="true">&raquo;</span>
            </a>
        </div>
    </nav>
</div>
