{% set tableClasses = 'wb-table' %}
{% if item.wbTableStriped %}{% set tableClasses = tableClasses ~ ' wb-table-striped' %}{% endif %}
{% if item.wbTableBordered %}{% set tableClasses = tableClasses ~ ' wb-table-bordered' %}{% endif %}
{% if item.wbTableHover %}{% set tableClasses = tableClasses ~ ' wb-table-hover' %}{% endif %}
{% if item.wbTableSm %}{% set tableClasses = tableClasses ~ ' wb-table-sm' %}{% endif %}

{% set hasBorder   = item.wbBorder ?? false %}
{% set borderColor = item.wbBorderColor.value ?? item.wbBorderColor ?? '' %}
{% set roundedVal  = item.wbRounded.value ?? item.wbRounded ?? '' %}
{% set paddingVal = item.wbPadding.value ?? item.wbPadding ?? '' %}
{% set titlePos    = item.wbTitlePosition.value ?? item.wbTitlePosition ?? 'outside' %}
{% set roundedMap  = {'rounded-1': 'var(--wb-r-sm)', 'rounded-2': 'var(--wb-r-md)', 'rounded-3': 'var(--wb-r-lg)', 'rounded-4': 'var(--wb-r-xl)', 'rounded-5': 'var(--wb-r-full)'} %}
{% set roundedCss  = roundedVal ? (roundedMap[roundedVal] ?? '') : '' %}
{% set extraStyle = '' %}
{% if hasBorder %}{% set extraStyle = extraStyle ~ 'border:1px solid var(--wb-border);' %}{% endif %}
{% if roundedCss %}{% set extraStyle = extraStyle ~ 'border-radius:' ~ roundedCss ~ ';' %}{% endif %}

{% set columns = item.wbTableColumns %}
{% set rows    = item.wbTableRows %}

{% if item.wbTitle and titlePos == 'outside' %}
    <h3 class="wb-mb-3">{{ item.wbTitle }}</h3>
{% endif %}
<div class="wb-block wb-table-block" style="margin-bottom:1.5rem;{{ extraStyle }}">
    {% if item.wbTitle and titlePos == 'inside' %}
        <h3 class="wb-mb-3">{{ item.wbTitle }}</h3>
    {% endif %}

    {% if columns | length %}
        {% set colCount = columns | length %}

        {% set tableHtml %}
            <table class="{{ tableClasses }}">
                {% if item.wbTableCaption %}
                    <caption>{{ item.wbTableCaption }}</caption>
                {% endif %}
                <thead>
                    <tr>
                        {% for col in columns %}
                            <th scope="col">{{ col.heading }}</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for row in rows %}
                        <tr>
                            {% for i in 1..colCount %}
                                <td>{{ attribute(row, 'cell' ~ i) }}</td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endset %}

        {% if item.wbTableResponsive %}
            <div class="wb-table-responsive" style="overflow-x:auto;">{{ tableHtml | raw }}</div>
        {% else %}
            {{ tableHtml | raw }}
        {% endif %}
    {% endif %}
</div>
