{# wbTabs — WebBlocks UI Kit tabs #}
{% set _tabItems = item.wbTabItems ? item.wbTabItems.all() : [] %}
{% set _align = item.wbTabAlign.value ?? '' %}
{% set _tabsId = 'wbTabs-' ~ item.id %}

{% if _tabItems|length %}
<div class="wb-block wb-tabs wb-mb-4">
    {% if item.wbTitle %}
        <h5 style="margin-bottom:0.75rem;">{{ item.wbTitle }}</h5>
    {% endif %}
    <div class="wb-tabs-nav{% if _align %} {{ _align }}{% endif %}" id="{{ _tabsId }}" role="tablist">
        {% for _tab in _tabItems %}
            {% set _tabId = _tabsId ~ '-tab-' ~ loop.index %}
            <button class="wb-tab {% if loop.first %}is-active{% endif %}"
                    id="{{ _tabId }}-btn"
                    data-wb-tab
                    data-wb-target="#{{ _tabId }}"
                    type="button"
                    role="tab"
                    aria-controls="{{ _tabId }}"
                    aria-selected="{{ loop.first ? 'true' : 'false' }}">
                {{ _tab.wbTabTitle }}
            </button>
        {% endfor %}
    </div>
    <div style="border:1px solid var(--wb-border);border-top:none;padding:1rem;" id="{{ _tabsId }}-content">
        {% for _tab in _tabItems %}
            {% set _tabId = _tabsId ~ '-tab-' ~ loop.index %}
            <div class="wb-tab-panel {% if loop.first %}is-active{% endif %}"
                 id="{{ _tabId }}"
                 role="tabpanel"
                 aria-labelledby="{{ _tabId }}-btn">
                {{ _tab.wbText }}
            </div>
        {% endfor %}
    </div>
</div>
{% endif %}
