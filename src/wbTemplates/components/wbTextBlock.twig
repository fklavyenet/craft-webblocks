{% set hasBorder  = item.wbBorder ?? false %}
{% set borderColor = item.wbBorderColor.value ?? item.wbBorderColor ?? '' %}
{% set rounded     = item.wbRounded.value ?? item.wbRounded ?? '' %}
{% set padding     = item.wbPadding.value ?? item.wbPadding ?? '' %}
{% set titlePos    = item.wbTitlePosition.value ?? item.wbTitlePosition ?? 'outside' %}
{% set extraClasses = '' %}
{% if hasBorder %}{% set extraClasses = extraClasses ~ ' wb-border' %}{% endif %}
{% if hasBorder and borderColor %}{% set extraClasses = extraClasses ~ ' wb-border-' ~ borderColor %}{% endif %}
{% if rounded %}{% set extraClasses = extraClasses ~ ' ' ~ rounded %}{% endif %}
{% if padding %}{% set extraClasses = extraClasses ~ ' ' ~ padding %}{% endif %}

{% if item.wbTitle and titlePos == 'outside' %}
    <h2>{{ item.wbTitle }}</h2>
{% endif %}
<div class="wb-block text-block wb-mb-4{{ extraClasses }}" style="{% if item.wbBackgroundColor %}background-color: {{ item.wbBackgroundColor }};{% endif %}" data-align="{{ item.wbAlignment|default('start') }}">
    {% if item.wbTitle and titlePos == 'inside' %}
        <h2>{{ item.wbTitle }}</h2>
    {% endif %}
    {% if item.wbText %}
        <div>{{ item.wbText }}</div>
    {% endif %}
</div>
