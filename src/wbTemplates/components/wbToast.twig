{% set variant = item.wbToastType.value ?? item.wbToastType ?? '' %}
<div class="wb-block mb-4">
    <div class="wb-toast{% if variant %} wb-toast-{{ variant }}{% endif %}" role="alert" aria-live="assertive" aria-atomic="true">
        {% if item.wbTitle %}
        <div class="wb-toast-header">
            <strong style="margin-inline-end:auto;">{{ item.wbTitle }}</strong>
            <button type="button" class="wb-toast-close" aria-label="Close"></button>
        </div>
        {% endif %}
        <div class="wb-toast-body">
            {{ item.wbText ?? '' }}
        </div>
    </div>
</div>
