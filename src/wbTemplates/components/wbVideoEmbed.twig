{# wbVideoEmbed — wb-native video embed for YouTube/Vimeo #}
{% set _url = item.wbVideoUrl ?? '' %}

{# Convert watch URL to embed URL #}
{% set _embedUrl = _url %}
{% if 'youtube.com/watch' in _url %}
    {% set _embedUrl = _url|replace({'youtube.com/watch?v=': 'youtube.com/embed/'}) %}
    {# Strip any extra query params after the video ID #}
    {% set _embedUrl = _embedUrl|split('&')[0] %}
{% elseif 'youtu.be/' in _url %}
    {% set _videoId = _url|split('youtu.be/')[1]|split('?')[0] %}
    {% set _embedUrl = 'https://www.youtube.com/embed/' ~ _videoId %}
{% elseif 'vimeo.com/' in _url and 'player.vimeo.com' not in _url %}
    {% set _videoId = _url|split('vimeo.com/')[1]|split('?')[0] %}
    {% set _embedUrl = 'https://player.vimeo.com/video/' ~ _videoId %}
{% endif %}

{% if _url %}
<div class="wb-block wb-video-embed" style="margin-bottom:1.5rem;">
    {% if item.wbTitle %}
        <h5 style="margin-bottom:0.75rem;">{{ item.wbTitle }}</h5>
    {% endif %}
    {% set _safeEmbedUrl = (_embedUrl|lower starts with 'javascript:' or _embedUrl|lower starts with 'data:') ? '' : _embedUrl %}
    {% if _safeEmbedUrl %}
    <div style="aspect-ratio:16/9;overflow:hidden;">
        <iframe src="{{ _safeEmbedUrl }}" style="width:100%;height:100%;border:0;"
                title="{{ item.wbTitle ?? 'Video' }}"
                allowfullscreen
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
        </iframe>
    </div>
    {% endif %}
</div>
{% endif %}
