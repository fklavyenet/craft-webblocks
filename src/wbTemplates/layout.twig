{% set _siteConfig = craft.app.globals.getSetByHandle('wbSiteConfig') ?? null %}
{% set _siteColorMode = _siteConfig ? (_siteConfig.wbColorMode.value ?? 'auto') : 'auto' %}
<!doctype html>
<html lang="{{ currentSite.language }}" data-bs-theme="{{ _siteColorMode == 'dark' ? 'dark' : 'light' }}" data-wb-mode="{{ _siteColorMode == 'dark' ? 'dark' : (_siteColorMode == 'light' ? 'light' : 'auto') }}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    {# ── Color mode: anti-flash script (runs before CSS paint) ── #}
    {# Must stay inline — contains Twig variable {{ _siteColorMode }} #}
    <script>
        (function () {
            var stored = localStorage.getItem('wbColorMode');
            var mode = (stored === 'light' || stored === 'dark' || stored === 'auto') ? stored : 'auto';
            var siteDefault = '{{ _siteColorMode }}';
            var resolved;
            if (mode === 'auto') {
                if (siteDefault === 'light' || siteDefault === 'dark') {
                    resolved = siteDefault;
                } else {
                    resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                }
            } else {
                resolved = mode;
            }
            document.documentElement.setAttribute('data-bs-theme', resolved);
            document.documentElement.setAttribute('data-wb-mode', mode);
        })();
    </script>

    {# ── SEO title ── #}
    {% block title %}
        <title>{{ entry.wbSeoTitle ?? entry.title ?? siteName }}</title>
    {% endblock %}

    {# ── SEO meta ── #}
    {% block meta %}
        {% if entry is defined %}
            {% set _seoTitle = entry.wbSeoTitle ?? entry.title ?? siteName %}
            {% set _seoDesc  = entry.wbSeoDescription ?? '' %}
            {% set _seoImg   = (entry.wbFeaturedImage is defined and entry.wbFeaturedImage is not null) ? entry.wbFeaturedImage.one() : null %}

            {% if _seoDesc %}
                <meta name="description" content="{{ _seoDesc }}">
            {% endif %}

            {# ── Open Graph ── #}
            <meta property="og:type"        content="website">
            <meta property="og:title"       content="{{ _seoTitle }}">
            <meta property="og:url"         content="{{ entry.url }}">
            {% if _seoDesc %}
                <meta property="og:description" content="{{ _seoDesc }}">
            {% endif %}
            {% if _seoImg %}
                <meta property="og:image"       content="{{ _seoImg.getUrl('wbOgImage') }}">
                <meta property="og:image:alt"   content="{{ _seoImg.alt ?: _seoImg.title }}">
            {% endif %}

            {# ── Twitter Card ── #}
            <meta name="twitter:card"  content="{{ _seoImg ? 'summary_large_image' : 'summary' }}">
            <meta name="twitter:title" content="{{ _seoTitle }}">
            {% if _seoDesc %}
                <meta name="twitter:description" content="{{ _seoDesc }}">
            {% endif %}
            {% if _seoImg %}
                <meta name="twitter:image"     content="{{ _seoImg.getUrl('wbOgImage') }}">
                <meta name="twitter:image:alt" content="{{ _seoImg.alt ?: _seoImg.title }}">
            {% endif %}
        {% endif %}
    {% endblock %}

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    {% block head %}{% endblock %}
    {{ head() }}
</head>
<body class="d-flex flex-column min-vh-100 {% block bodyClass %}{% endblock %}">
{{ beginBody() }}

{# ── Navbar ── #}
{% block navbar %}
    {% set siteConfig = craft.app.globals.getSetByHandle('wbSiteConfig') ?? null %}
    {% if siteConfig %}
        {% set navbarEntry = siteConfig.wbSiteNavbar.one() ?? null %}
        {% if navbarEntry %}
            {% set item = navbarEntry %}
            {% include "wb/components/wbNavbar" %}
        {% endif %}
    {% endif %}
{% endblock %}

{# ── Page content ── #}
<main class="{% block mainClass %}container py-4{% endblock %} flex-grow-1">
    {% block content %}{% endblock %}
</main>

{# ── Footer ── #}
{% block footer %}
    {% set siteConfig = craft.app.globals.getSetByHandle('wbSiteConfig') ?? null %}
    {% if siteConfig %}
        {% set footerEntry = siteConfig.wbSiteFooter.one() ?? null %}
        {% if footerEntry %}
            {% set item = footerEntry %}
            {% include "wb/partials/footer" %}
        {% endif %}
    {% endif %}
{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

{% block scripts %}{% endblock %}

{# ── Cookie consent banner (rendered after Bootstrap so buttons inherit styles) ── #}
{% include "wb/partials/cookie-banner" %}

{{ endBody() }}
</body>
</html>
