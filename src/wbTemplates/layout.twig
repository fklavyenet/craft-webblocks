{% set _siteConfig = craft.app.globals.getSetByHandle('wbSiteConfig') ?? null %}
{% set _siteColorMode = _siteConfig ? (_siteConfig.wbColorMode.value ?? 'auto') : 'auto' %}
{% set _siteColorTheme = _siteConfig ? (_siteConfig.wbColorTheme.value ?? 'default') : 'default' %}
{% set _googleFontsUrl = _siteConfig ? (_siteConfig.wbGoogleFontsUrl ?? '') : '' %}
{% set _customCssUrl = _siteConfig ? (_siteConfig.wbCustomCssUrl ?? '') : '' %}
{% set _customCss = _siteConfig ? (_siteConfig.wbCustomCss ?? '') : '' %}

<!doctype html>
<html lang="{{ currentSite.language }}"
      data-mode="{{ _siteColorMode == 'dark' ? 'dark' : (_siteColorMode == 'light' ? 'light' : 'auto') }}"
      {% if _siteColorTheme not in ['default',''] %}data-accent="{{ _siteColorTheme }}"{% endif %}>
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    {# ── Color mode: anti-flash script (runs before CSS paint) ── #}
    {# Must stay inline — contains Twig variable {{ _siteColorMode }} #}
    <script>
        (function () {
            var stored = localStorage.getItem('wbColorMode');
            var mode = (stored === 'light' || stored === 'dark' || stored === 'auto') ? stored : 'auto';
            var siteDefault = '{{ _siteColorMode }}';
            var resolved;
            if (mode === 'auto') {
                if (siteDefault === 'light' || siteDefault === 'dark') {
                    resolved = siteDefault;
                } else {
                    resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                }
            } else {
                resolved = mode;
            }
            document.documentElement.setAttribute('data-mode', mode);
        })();
    </script>

    {# ── SEO title ── #}
    {# If wbSeoTitle is set use it as-is; otherwise apply seoTitleFormat from plugin settings #}
    {% set _wbSettings   = craft.app.plugins.isPluginEnabled('webblocks') ? craft.webblocks.settings : null %}
    {% set _titleFormat  = _wbSettings.seoTitleFormat ?? '{title} — {siteName}' %}
    {% set _rawTitle     = entry.wbSeoTitle ?? entry.title ?? siteName %}
    {% set _formattedTitle = entry.wbSeoTitle
        ? entry.wbSeoTitle
        : (_titleFormat
            | replace({'{title}': (entry.title ?? siteName), '{siteName}': siteName})
          ) %}
    {% block title %}
        <title>{{ _formattedTitle }}</title>
    {% endblock %}

    {# ── SEO meta ── #}
    {% block meta %}
        {% if entry is defined %}
            {% set _seoTitle = _formattedTitle %}
            {% set _seoDesc  = entry.wbSeoDescription ?? '' %}
            {% set _seoImg   = (entry.wbFeaturedImage is defined and entry.wbFeaturedImage is not null) ? entry.wbFeaturedImage.one() : null %}

            {% if _seoDesc %}
                <meta name="description" content="{{ _seoDesc }}">
            {% endif %}

            {# ── Open Graph ── #}
            <meta property="og:type"        content="website">
            <meta property="og:title"       content="{{ _seoTitle }}">
            <meta property="og:url"         content="{{ entry.url }}">
            {% if _seoDesc %}
                <meta property="og:description" content="{{ _seoDesc }}">
            {% endif %}
            {% if _seoImg %}
                <meta property="og:image"       content="{{ _seoImg.getUrl('wbOgImage') }}">
                <meta property="og:image:alt"   content="{{ _seoImg.alt ?: _seoImg.title }}">
            {% endif %}

            {# ── Twitter Card ── #}
            <meta name="twitter:card"  content="{{ _seoImg ? 'summary_large_image' : 'summary' }}">
            <meta name="twitter:title" content="{{ _seoTitle }}">
            {% if _seoDesc %}
                <meta name="twitter:description" content="{{ _seoDesc }}">
            {% endif %}
            {% if _seoImg %}
                <meta name="twitter:image"     content="{{ _seoImg.getUrl('wbOgImage') }}">
                <meta name="twitter:image:alt" content="{{ _seoImg.alt ?: _seoImg.title }}">
            {% endif %}
        {% endif %}
    {% endblock %}

    {# ── Google Fonts ── #}
    {% if _googleFontsUrl %}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="{{ _googleFontsUrl }}" rel="stylesheet">
    {% endif %}

    {# ── WebBlocks UI Kit CSS ── #}
    <link href="https://cdn.jsdelivr.net/gh/fklavyenet/webblocks-ui@master/dist/webblocks-ui.css" rel="stylesheet" crossorigin="anonymous">

    {% block head %}{% endblock %}
    {{ head() }}

    {# ── Custom CSS URL + inline styles — loaded after wb-blocks.css ── #}
    {% if _customCssUrl %}
        <link href="{{ _customCssUrl }}" rel="stylesheet" crossorigin="anonymous">
    {% endif %}
    {% if _customCss %}
        <style>{{ _customCss | replace({'</style>': '<\\/style>', '</STYLE>': '<\\/STYLE>'}) | raw }}</style>
    {% endif %}

    {# ── Analytics ── #}
    {% set _ga4Id     = _wbSettings.ga4MeasurementId ?? null %}
    {% set _matomoUrl = _wbSettings.matomoUrl ?? null %}
    {% set _matomoId  = _wbSettings.matomoSiteId ?? null %}

    {% if _ga4Id %}
        {# Google Analytics 4 #}
        <script async src="https://www.googletagmanager.com/gtag/js?id={{ _ga4Id | e }}"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '{{ _ga4Id | e }}');
        </script>
    {% endif %}

    {% if _matomoUrl and _matomoId %}
        {# Matomo #}
        <script>
            var _paq = window._paq = window._paq || [];
            _paq.push(['trackPageView']);
            _paq.push(['enableLinkTracking']);
            (function() {
                var u = '{{ _matomoUrl | trim('/') | e }}/';
                _paq.push(['setTrackerUrl', u + 'matomo.php']);
                _paq.push(['setSiteId', '{{ _matomoId | e }}']);
                var d = document, g = d.createElement('script'), s = d.getElementsByTagName('script')[0];
                g.async = true; g.src = u + 'matomo.js'; s.parentNode.insertBefore(g, s);
            })();
        </script>
    {% endif %}
</head>
<body class="wb-page {% block bodyClass %}{% endblock %}" style="display:flex;flex-direction:column;min-height:100vh;">
{{ beginBody() }}

{# ── Navbar ── #}
{% block navbar %}
    {% set siteConfig = craft.app.globals.getSetByHandle('wbSiteConfig') ?? null %}
    {% if siteConfig %}
        {% set navbarEntry = siteConfig.wbSiteNavbar.one() ?? null %}
        {% if navbarEntry %}
            {% set item = navbarEntry %}
            {% include "wb/components/wbNavbar" %}
        {% endif %}
    {% endif %}
{% endblock %}

{# ── Page content ── #}
<main class="{% block mainClass %}wb-container wb-section{% endblock %}" style="flex:1;">
    {% block content %}{% endblock %}
</main>

{# ── Footer ── #}
{% block footer %}
    {% set siteConfig = craft.app.globals.getSetByHandle('wbSiteConfig') ?? null %}
    {% if siteConfig %}
        {% set footerEntry = siteConfig.wbSiteFooter.one() ?? null %}
        {% if footerEntry %}
            {% set item = footerEntry %}
            {% include "wb/partials/footer" %}
        {% endif %}
    {% endif %}
{% endblock %}

<script src="https://cdn.jsdelivr.net/gh/fklavyenet/webblocks-ui@master/dist/webblocks-ui.js" crossorigin="anonymous"></script>

{% block scripts %}{% endblock %}

{# ── Cookie consent banner ── #}
{% include "wb/partials/cookie-banner" %}

{{ endBody() }}
</body>
</html>
