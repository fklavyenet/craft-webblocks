{% set _siteConfig = craft.app.globals.getSetByHandle('wbSiteConfig') ?? null %}
{% set _siteColorMode = _siteConfig ? (_siteConfig.wbColorMode.value ?? 'auto') : 'auto' %}
<!doctype html>
<html lang="{{ currentSite.language }}" data-bs-theme="{{ _siteColorMode == 'dark' ? 'dark' : 'light' }}" data-wb-mode="{{ _siteColorMode == 'dark' ? 'dark' : (_siteColorMode == 'light' ? 'light' : 'auto') }}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    {# ── Color mode: anti-flash script (runs before CSS paint) ── #}
    <script>
        (function () {
            var stored = localStorage.getItem('wbColorMode');
            var mode = (stored === 'light' || stored === 'dark' || stored === 'auto') ? stored : 'auto';
            var siteDefault = '{{ _siteColorMode }}';
            var resolved;
            if (mode === 'auto') {
                if (siteDefault === 'light' || siteDefault === 'dark') {
                    resolved = siteDefault;
                } else {
                    resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                }
            } else {
                resolved = mode;
            }
            document.documentElement.setAttribute('data-bs-theme', resolved);
            document.documentElement.setAttribute('data-wb-mode', mode);
        })();
    </script>

    {# ── SEO title ── #}
    {% block title %}
        <title>{{ entry.wbSeoTitle ?? entry.title ?? siteName }}</title>
    {% endblock %}

    {# ── SEO meta ── #}
    {% block meta %}
        {% if entry is defined %}
            {% set _seoTitle = entry.wbSeoTitle ?? entry.title ?? siteName %}
            {% set _seoDesc  = entry.wbSeoDescription ?? '' %}
            {% set _seoImg   = (entry.wbFeaturedImage is defined and entry.wbFeaturedImage is not null) ? entry.wbFeaturedImage.one() : null %}

            {% if _seoDesc %}
                <meta name="description" content="{{ _seoDesc }}">
            {% endif %}

            {# ── Open Graph ── #}
            <meta property="og:type"        content="website">
            <meta property="og:title"       content="{{ _seoTitle }}">
            <meta property="og:url"         content="{{ entry.url }}">
            {% if _seoDesc %}
                <meta property="og:description" content="{{ _seoDesc }}">
            {% endif %}
            {% if _seoImg %}
                <meta property="og:image"       content="{{ _seoImg.getUrl('wbOgImage') }}">
                <meta property="og:image:alt"   content="{{ _seoImg.alt ?: _seoImg.title }}">
            {% endif %}

            {# ── Twitter Card ── #}
            <meta name="twitter:card"  content="{{ _seoImg ? 'summary_large_image' : 'summary' }}">
            <meta name="twitter:title" content="{{ _seoTitle }}">
            {% if _seoDesc %}
                <meta name="twitter:description" content="{{ _seoDesc }}">
            {% endif %}
            {% if _seoImg %}
                <meta name="twitter:image"     content="{{ _seoImg.getUrl('wbOgImage') }}">
                <meta name="twitter:image:alt" content="{{ _seoImg.alt ?: _seoImg.title }}">
            {% endif %}
        {% endif %}
    {% endblock %}

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    {# ── Color mode toggle icons ── #}
    <style>
        .wb-theme-icon { display: none; }
        html[data-wb-mode="light"] .wb-theme-icon-light { display: inline; }
        html[data-wb-mode="dark"]  .wb-theme-icon-dark  { display: inline; }
        html[data-wb-mode="auto"]  .wb-theme-icon-auto  { display: inline; }
        /* Ensure toggle button inherits navbar text colour instead of Bootstrap's link blue */
        .wb-color-mode-toggle { color: inherit; }
        .wb-color-mode-toggle:hover { opacity: 0.75; }
    </style>

    {# ── Hero block styles ── #}
    <style>
        .wb-block.hero {
            position: relative;
            min-height: 480px;
            display: flex;
            align-items: center;
            overflow: hidden;
        }
        /* Base dim — takes the edge off very bright images */
        .wb-block.hero .hero-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.25);
            display: flex;
            align-items: center;
            width: 100%;
        }
        .wb-block.hero[data-align="center"] .hero-overlay { justify-content: center; }
        .wb-block.hero[data-align="end"]    .hero-overlay { justify-content: flex-end; }
        .wb-block.hero[data-align="start"]  .hero-overlay { justify-content: flex-start; }
        /* Gradient scrim: dark at the content area, fades toward the opposite edge */
        .wb-block.hero .hero-overlay::after {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            background: linear-gradient(
                to top,
                rgba(0,0,0,0.72) 0%,
                rgba(0,0,0,0.36) 40%,
                rgba(0,0,0,0) 100%
            );
        }
        .wb-block.hero .hero-content {
            position: relative;
            z-index: 1;
            padding: 3rem 2rem;
            color: #fff;
            max-width: 720px;
        }
        .wb-block.hero[data-align="center"] .hero-content { text-align: center; }
        .wb-block.hero[data-align="end"]    .hero-content { text-align: end; }
        .wb-block.hero .hero-content h1 {
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 700;
            text-shadow: 0 2px 12px rgba(0,0,0,.6);
        }
        .wb-block.hero .hero-content p {
            font-size: clamp(1rem, 2vw, 1.25rem);
            text-shadow: 0 1px 6px rgba(0,0,0,.6);
            margin-bottom: 0;
        }

        /* ── Carousel caption scrim ── */
        .wb-carousel .carousel-item {
            position: relative;
        }
        .wb-carousel .carousel-item::after {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            background: linear-gradient(
                to top,
                rgba(0,0,0,0.72) 0%,
                rgba(0,0,0,0.24) 45%,
                rgba(0,0,0,0) 100%
            );
        }
        .wb-carousel .carousel-caption {
            position: absolute;
            z-index: 1;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            border-radius: 6px;
            padding: 0.75rem 1.25rem;
            color: #fff;
            text-shadow: 0 1px 4px rgba(0,0,0,.6);
        }
        .wb-carousel .carousel-caption h5,
        .wb-carousel .carousel-caption p {
            text-shadow: 0 1px 6px rgba(0,0,0,.6);
            margin-bottom: 0;
        }
        .wb-carousel .carousel-caption h5 {
            margin-bottom: 0.25rem;
        }
    </style>

    {% block head %}{% endblock %}
    {{ head() }}
</head>
<body class="d-flex flex-column min-vh-100 {% block bodyClass %}{% endblock %}">
{{ beginBody() }}

{# ── Navbar ── #}
{% block navbar %}
    {% set siteConfig = craft.app.globals.getSetByHandle('wbSiteConfig') ?? null %}
    {% if siteConfig %}
        {% set navbarEntry = siteConfig.wbSiteNavbar.one() ?? null %}
        {% if navbarEntry %}
            {% set item = navbarEntry %}
            {% include "wb/components/wbNavbar" %}
        {% endif %}
    {% endif %}
{% endblock %}

{# ── Page content ── #}
<main class="{% block mainClass %}container py-4{% endblock %} flex-grow-1">
    {% block content %}{% endblock %}
</main>

{# ── Footer ── #}
{% block footer %}
    {% set siteConfig = craft.app.globals.getSetByHandle('wbSiteConfig') ?? null %}
    {% if siteConfig %}
        {% set footerEntry = siteConfig.wbSiteFooter.one() ?? null %}
        {% if footerEntry %}
            {% set item = footerEntry %}
            {% include "wb/partials/footer" %}
        {% endif %}
    {% endif %}
{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {

        // ── WB Masonry ────────────────────────────────────────────────────────
        // CSS-grid row-span masonry. No absolute positioning — overflow impossible.
        // Each item gets grid-row: span N so it fills its natural height.
        // grid-auto-rows is set to rowSize px so spans map 1:1 to pixels.
        (function () {
            var ROW_SIZE = 4; // px — smaller = more precise, but more rows

            function layout(grid) {
                var cs     = getComputedStyle(grid);
                var gapY   = parseFloat(cs.rowGap) || 0;

                // Set a fine row grid so spans can approximate any height
                grid.style.gridAutoRows = ROW_SIZE + 'px';
                grid.style.alignItems   = 'start';

                Array.from(grid.children).forEach(function (item) {
                    // Reset span so item shrinks to natural height
                    item.style.gridRow = '';

                    var h    = item.getBoundingClientRect().height;
                    var span = Math.ceil((h + gapY) / (ROW_SIZE + gapY));
                    item.style.gridRow = 'span ' + span;
                });
            }

            document.querySelectorAll('[data-wb-masonry]').forEach(function (grid) {
                layout(grid);

                // Re-run after each image loads
                grid.querySelectorAll('img').forEach(function (img) {
                    if (!img.complete) {
                        img.addEventListener('load',  function () { layout(grid); });
                        img.addEventListener('error', function () { layout(grid); });
                    }
                });

                // Re-run on resize with debounce
                var resizeTimer;
                window.addEventListener('resize', function () {
                    clearTimeout(resizeTimer);
                    resizeTimer = setTimeout(function () { layout(grid); }, 100);
                });
            });
        })();

        // ── WB Lightbox ───────────────────────────────────────────────────────
        // Reads data-fancybox (group name) and data-caption from <a> elements.
        // Pure vanilla JS, zero dependencies, MIT-compatible.
        (function () {
            // Build overlay DOM once
            var overlay = document.createElement('div');
            overlay.id = 'wb-lightbox';
            overlay.setAttribute('role', 'dialog');
            overlay.setAttribute('aria-modal', 'true');
            overlay.setAttribute('aria-label', 'Image viewer');
            overlay.innerHTML =
                '<button class="wb-lb-close" aria-label="Close">&times;</button>' +
                '<button class="wb-lb-prev" aria-label="Previous">&#8249;</button>' +
                '<button class="wb-lb-next" aria-label="Next">&#8250;</button>' +
                '<div class="wb-lb-content">' +
                    '<img class="wb-lb-img" src="" alt="">' +
                    '<p class="wb-lb-caption"></p>' +
                '</div>';
            document.body.appendChild(overlay);

            var style = document.createElement('style');
            style.textContent = [
                '#wb-lightbox{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.92);align-items:center;justify-content:center;}',
                '#wb-lightbox.wb-lb-open{display:flex;}',
                '.wb-lb-content{display:flex;flex-direction:column;align-items:center;max-width:92vw;max-height:92vh;}',
                '.wb-lb-img{max-width:90vw;max-height:82vh;object-fit:contain;border-radius:4px;}',
                '.wb-lb-caption{color:#ddd;margin:10px 0 0;font-size:.9rem;text-align:center;max-width:80vw;}',
                '.wb-lb-close{position:fixed;top:16px;right:20px;background:none;border:none;color:#fff;font-size:2.4rem;line-height:1;cursor:pointer;opacity:.8;}',
                '.wb-lb-close:hover{opacity:1;}',
                '.wb-lb-prev,.wb-lb-next{position:fixed;top:50%;transform:translateY(-50%);background:none;border:none;color:#fff;font-size:3.5rem;line-height:1;cursor:pointer;padding:0 16px;opacity:.7;user-select:none;}',
                '.wb-lb-prev:hover,.wb-lb-next:hover{opacity:1;}',
                '.wb-lb-prev{left:4px;}.wb-lb-next{right:4px;}',
            ].join('');
            document.head.appendChild(style);

            var groups = {};   // groupName → [{ href, caption }]
            var current = { group: null, index: 0 };

            // Index all data-fancybox links
            function indexLinks() {
                groups = {};
                document.querySelectorAll('a[data-fancybox]').forEach(function (a) {
                    var g = a.getAttribute('data-fancybox');
                    if (!groups[g]) groups[g] = [];
                    groups[g].push({ href: a.href, caption: a.getAttribute('data-caption') || '' });
                    a.addEventListener('click', function (e) {
                        e.preventDefault();
                        var idx = groups[g].indexOf(groups[g].find(function (item) { return item.href === a.href; }));
                        open(g, idx);
                    });
                });
            }

            function open(group, index) {
                current.group = group;
                current.index = index;
                show();
                overlay.classList.add('wb-lb-open');
                document.body.style.overflow = 'hidden';
                overlay.querySelector('.wb-lb-close').focus();
            }

            function close() {
                overlay.classList.remove('wb-lb-open');
                document.body.style.overflow = '';
            }

            function show() {
                var items = groups[current.group];
                var item  = items[current.index];
                var img   = overlay.querySelector('.wb-lb-img');
                img.src = item.href;
                img.alt = item.caption;
                overlay.querySelector('.wb-lb-caption').textContent = item.caption;
                overlay.querySelector('.wb-lb-prev').style.visibility = items.length > 1 ? '' : 'hidden';
                overlay.querySelector('.wb-lb-next').style.visibility = items.length > 1 ? '' : 'hidden';
            }

            function prev() { var n = groups[current.group].length; current.index = (current.index - 1 + n) % n; show(); }
            function next() { var n = groups[current.group].length; current.index = (current.index + 1) % n; show(); }

            overlay.querySelector('.wb-lb-close').addEventListener('click', close);
            overlay.querySelector('.wb-lb-prev').addEventListener('click', prev);
            overlay.querySelector('.wb-lb-next').addEventListener('click', next);
            overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });

            document.addEventListener('keydown', function (e) {
                if (!overlay.classList.contains('wb-lb-open')) return;
                if (e.key === 'Escape')     close();
                if (e.key === 'ArrowLeft')  prev();
                if (e.key === 'ArrowRight') next();
            });

            indexLinks();
        })();

    });
</script>

{% block scripts %}
<script>
    (function () {
        var CYCLE = ['light', 'dark', 'auto'];
        var mq = window.matchMedia('(prefers-color-scheme: dark)');

        function applyMode(mode) {
            var resolved = (mode === 'auto') ? (mq.matches ? 'dark' : 'light') : mode;
            document.documentElement.setAttribute('data-bs-theme', resolved);
            document.documentElement.setAttribute('data-wb-mode', mode);
            localStorage.setItem('wbColorMode', mode);
        }

        // Initialise from localStorage
        applyMode(localStorage.getItem('wbColorMode') || 'auto');

        // React to OS-level changes when in auto mode
        mq.addEventListener('change', function () {
            if ((localStorage.getItem('wbColorMode') || 'auto') === 'auto') {
                applyMode('auto');
            }
        });

        // Wire up all toggle buttons on the page
        document.querySelectorAll('.wb-color-mode-toggle').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var current = localStorage.getItem('wbColorMode') || 'auto';
                applyMode(CYCLE[(CYCLE.indexOf(current) + 1) % CYCLE.length]);
            });
        });
    })();
</script>
{% endblock %}
{{ endBody() }}
</body>
</html>
