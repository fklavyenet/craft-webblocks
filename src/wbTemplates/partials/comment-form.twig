{#
  wb/partials/comment-form.twig
  Variables expected:
    entry  — the wbPost entry this form belongs to
#}
{% set lang = currentSite.language|slice(0, 2) %}

{% set labels = {
    en: {
        heading:     'Leave a comment',
        name:        'Name',
        email:       'Email address',
        comment:     'Comment',
        submit:      'Post comment',
        namePh:      'Your name',
        emailPh:     'your@email.com',
        commentPh:   'Write your comment here…',
        nameReq:     'Please enter your name.',
        emailReq:    'Please enter a valid email address.',
        commentReq:  'Please write your comment.',
        success:     'Thank you! Your comment is awaiting moderation.',
        emailNote:   'Your email will not be published.',
        privacy:     'We keep your information private.',
    },
    tr: {
        heading:     'Yorum yap',
        name:        'Ad Soyad',
        email:       'E-posta adresi',
        comment:     'Yorum',
        submit:      'Yorum gönder',
        namePh:      'Adınızı girin',
        emailPh:     'eposta@adresiniz.com',
        commentPh:   'Yorumunuzu buraya yazın…',
        nameReq:     'Lütfen adınızı girin.',
        emailReq:    'Lütfen geçerli bir e-posta adresi girin.',
        commentReq:  'Lütfen yorumunuzu yazın.',
        success:     'Teşekkürler! Yorumunuz onay bekliyor.',
        emailNote:   'E-posta adresiniz yayınlanmayacak.',
        privacy:     'Bilgileriniz gizli tutulur.',
    },
    de: {
        heading:     'Kommentar hinterlassen',
        name:        'Name',
        email:       'E-Mail-Adresse',
        comment:     'Kommentar',
        submit:      'Kommentar senden',
        namePh:      'Ihr Name',
        emailPh:     'ihre@email.de',
        commentPh:   'Schreiben Sie Ihren Kommentar hier…',
        nameReq:     'Bitte geben Sie Ihren Namen ein.',
        emailReq:    'Bitte geben Sie eine gültige E-Mail-Adresse ein.',
        commentReq:  'Bitte schreiben Sie Ihren Kommentar.',
        success:     'Danke! Ihr Kommentar wartet auf Freischaltung.',
        emailNote:   'Ihre E-Mail-Adresse wird nicht veröffentlicht.',
        privacy:     'Ihre Daten werden vertraulich behandelt.',
    }
} %}

{% set t = labels[lang] ?? labels['en'] %}

{% set formId = 'wb-comment-form-' ~ entry.id %}
{% set actionUrl = actionUrl('webblocks/comment/submit') %}

{# ── Flash success ──────────────────────────────────────────────────────────── #}
{% if craft.app.session.getFlash('wbCommentSuccess') %}
    <div class="wb-alert wb-alert-success" role="alert">
        {{ t.success }}
    </div>
{% else %}

<div class="wb-comment-form" style="margin-top:3rem;">
    <h3 style="margin-bottom:1.5rem;">{{ t.heading }}</h3>

    {# ── Validation errors (non-Ajax fallback) ── #}
    {% if craft.app.session.getFlash('wbCommentError') %}
        <div class="wb-alert wb-alert-danger" role="alert">
            {{ craft.app.session.getFlash('wbCommentError') }}
        </div>
    {% endif %}

    <form id="{{ formId }}" method="post" action="{{ actionUrl }}" novalidate>
        {{ csrfInput() }}
        <input type="hidden" name="postEntryId" value="{{ entry.id }}">
        {{ redirectInput(craft.app.request.url ~ '#wb-comments') }}

        {# ── Honeypot (hidden, must stay empty) ── #}
        <div class="wb-hp" aria-hidden="true" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">
            <label for="{{ formId }}-hp">Leave this blank</label>
            <input type="text" id="{{ formId }}-hp" name="wbhp" tabindex="-1" autocomplete="off">
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;">
            {# Name #}
            <div>
                <label for="{{ formId }}-name" class="wb-label" style="font-weight:600;">
                    {{ t.name }}<span style="color:var(--wb-danger,#dc2626);margin-inline-start:0.25rem;" aria-hidden="true">*</span>
                </label>
                <input type="text"
                       id="{{ formId }}-name"
                       name="wbCommentAuthorName"
                       class="wb-input"
                       placeholder="{{ t.namePh }}"
                       maxlength="100"
                       required>
                <div class="wb-field-error" id="{{ formId }}-name-error" style="display:none;">{{ t.nameReq }}</div>
            </div>

            {# Email #}
            <div>
                <label for="{{ formId }}-email" class="wb-label" style="font-weight:600;">
                    {{ t.email }}<span style="color:var(--wb-danger,#dc2626);margin-inline-start:0.25rem;" aria-hidden="true">*</span>
                </label>
                <input type="email"
                       id="{{ formId }}-email"
                       name="wbEmail"
                       class="wb-input"
                       placeholder="{{ t.emailPh }}"
                       required>
                <div class="wb-field-error" id="{{ formId }}-email-error" style="display:none;">{{ t.emailReq }}</div>
                <div class="wb-field-hint">{{ t.emailNote }}</div>
            </div>
        </div>

        {# Comment body #}
        <div style="margin-top:1rem;">
            <label for="{{ formId }}-body" class="wb-label" style="font-weight:600;">
                {{ t.comment }}<span style="color:var(--wb-danger,#dc2626);margin-inline-start:0.25rem;" aria-hidden="true">*</span>
            </label>
            <textarea id="{{ formId }}-body"
                      name="wbCommentBody"
                      class="wb-textarea"
                      rows="5"
                      placeholder="{{ t.commentPh }}"
                      maxlength="1000"
                      required></textarea>
            <div class="wb-field-error" id="{{ formId }}-body-error" style="display:none;">{{ t.commentReq }}</div>
        </div>

        {# Submit #}
        <div style="margin-top:1rem;">
            <button type="submit" class="wb-btn wb-btn-primary">{{ t.submit }}</button>
        </div>
    </form>

    {# Success (Ajax) #}
    <div id="{{ formId }}-success" class="wb-alert wb-alert-success" style="display:none;margin-top:1rem;" role="alert">
        {{ t.success }}
    </div>
</div>

{# ── JavaScript ─────────────────────────────────────────────────────────────── #}
<script>
(function () {
    var form    = document.getElementById('{{ formId }}');
    var success = document.getElementById('{{ formId }}-success');
    if (!form) return;

    form.addEventListener('submit', function (e) {
        e.preventDefault();

        // Clear previous errors
        form.querySelectorAll('.wb-input.is-invalid, .wb-textarea.is-invalid').forEach(function (el) { el.classList.remove('is-invalid'); });
        form.querySelectorAll('.wb-field-error').forEach(function (el) { el.style.display = 'none'; });

        var data = new FormData(form);

        fetch(form.action, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: data
        })
        .then(function (res) { return res.json(); })
        .then(function (json) {
            if (json.success) {
                form.style.display = 'none';
                success.style.display = '';
            } else {
                var errors = json.errors || {};
                var fieldMap = {
                    wbCommentAuthorName: '{{ formId }}-name',
                    wbEmail:             '{{ formId }}-email',
                    wbCommentBody:       '{{ formId }}-body'
                };
                Object.keys(fieldMap).forEach(function (field) {
                    if (errors[field]) {
                        var input = form.querySelector('[name="' + field + '"]');
                        if (input) input.classList.add('is-invalid');
                        var errEl = document.getElementById(fieldMap[field] + '-error');
                        if (errEl) errEl.style.display = '';
                    }
                });
            }
        })
        .catch(function () {
            form.submit();
        });
    });
}());
</script>

{% endif %} {# end flash success check #}
