{#
  wb/partials/comment-list.twig
  Variables expected:
    entry  — the wbPost entry whose comments to list
#}
{% set lang = currentSite.language|slice(0, 2) %}

{% set labels = {
    en: {
        heading:    'Comments',
        noComments: 'Be the first to comment!',
        one:        '1 comment',
        many:       '%d comments',
    },
    tr: {
        heading:    'Yorumlar',
        noComments: 'İlk yorumu sen yap!',
        one:        '1 yorum',
        many:       '%d yorum',
    },
    de: {
        heading:    'Kommentare',
        noComments: 'Sei der Erste, der kommentiert!',
        one:        '1 Kommentar',
        many:       '%d Kommentare',
    }
} %}
{% set t = labels[lang] ?? labels['en'] %}

{# Fetch approved (enabled/live) comments for this post #}
{% set comments = craft.entries()
    .section('wbComments')
    .wbCommentPost(entry.id)
    .status('live')
    .orderBy('postDate asc')
    .all() %}

{% if comments|length %}
    <section id="wb-comments" class="wb-comment-list" style="margin-top:3rem;">
        {% set count = comments|length %}
        <h3 style="margin-bottom:1.5rem;">
            {% if count == 1 %}
                {{ t.one }}
            {% else %}
                {{ t.many|replace({'%d': count}) }}
            {% endif %}
        </h3>

        {% for comment in comments %}
            <div class="wb-comment" style="display:flex;gap:0.75rem;margin-bottom:1.5rem;">

                {# Avatar placeholder #}
                <div class="wb-comment-avatar"
                     style="flex-shrink:0;width:44px;height:44px;border-radius:50%;background:var(--wb-surface-2,#e5e7eb);display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:600;color:var(--wb-muted);">
                    {{ comment.wbCommentAuthorName|slice(0,1)|upper }}
                </div>

                <div style="flex:1;">
                    <div style="display:flex;align-items:baseline;gap:0.5rem;margin-bottom:0.25rem;">
                        <strong class="wb-comment-author">{{ comment.wbCommentAuthorName }}</strong>
                        <small style="color:var(--wb-muted);">{{ comment.postDate|date('d.m.Y') }}</small>
                    </div>
                    <p class="wb-m-0 wb-comment-body">{{ comment.wbCommentBody|nl2br }}</p>
                </div>

            </div>
            {% if not loop.last %}
                <hr class="wb-comment-divider" style="border:none;border-top:1px solid var(--wb-border);margin:0 0 1.5rem;">
            {% endif %}
        {% endfor %}
    </section>
{% else %}
    <section id="wb-comments" class="wb-comment-list" style="margin-top:3rem;">
        <p style="color:var(--wb-muted);font-style:italic;">{{ t.noComments }}</p>
    </section>
{% endif %}
