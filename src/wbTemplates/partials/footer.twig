{% set footerLinks = item.wbFooterLinks.all() %}
{% set brand      = item.wbNavbarBrand ?? null %}
{% set logo       = item.wbNavbarLogo.one() ?? null %}
{% set tagline    = item.wbFooterTagline ?? null %}
{% set copyright  = item.wbFooterCopyright ?? null %}

{# Auto-collect entries with wbShowInFooter enabled when no manual links are defined #}
{% if not footerLinks|length %}
    {% set autoFooterEntries = craft.entries()
        .wbShowInFooter(true)
        .all()
        |sort((a, b) =>
            (a.wbFooterOrder ? a.wbFooterOrder : 9999) - (b.wbFooterOrder ? b.wbFooterOrder : 9999)
        ) %}
{% endif %}

{% set resolvedLinks = footerLinks|length ? footerLinks : (autoFooterEntries is defined ? autoFooterEntries : []) %}

<footer class="wb-footer border-top bg-body-tertiary mt-auto pt-5 pb-4">
    <div class="container">

        {# ── Top row: brand + links ── #}
        <div class="row pb-4">

            {# Brand + tagline #}
            <div class="col-md-5 mb-4 mb-md-0">
                {% if logo %}
                    <img src="{{ logo.url }}" alt="{{ brand ?? logo.alt ?: logo.title }}" height="32" class="d-block mb-2">
                {% endif %}
                {% if brand %}
                    <div class="fw-semibold fs-5 mb-1">{{ brand }}</div>
                {% endif %}
                {% if tagline %}
                    <p class="text-body-secondary small mb-0">{{ tagline }}</p>
                {% endif %}
            </div>

            {# Nav links #}
            {% if resolvedLinks|length %}
                <div class="col-md-7">
                    <ul class="list-unstyled d-flex flex-wrap gap-3 mb-0 justify-content-md-end">
                        {% for link in resolvedLinks %}
                            {% if link.wbFooterLinkUrl is defined %}
                                {# manual link entry #}
                                <li>
                                    <a href="{{ link.wbFooterLinkUrl ?? '#' }}" class="text-body-secondary text-decoration-none wb-footer-link">
                                        {{ link.wbFooterLinkLabel }}
                                    </a>
                                </li>
                            {% else %}
                                {# auto entry #}
                                <li>
                                    <a href="{{ link.url }}" class="text-body-secondary text-decoration-none wb-footer-link">
                                        {{ link.title }}
                                    </a>
                                </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

        </div>

        {# ── Bottom row: copyright + cookie settings ── #}
        {% set _cs = craft.app.globals.getSetByHandle('wbCookieSettings') ?? null %}
        {% if copyright or (_cs and _cs.wbCookieBannerEnabled) %}
            <div class="border-top pt-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
                {% if copyright %}
                    <small class="text-body-secondary">{{ copyright }}</small>
                {% endif %}
                {% if _cs and _cs.wbCookieBannerEnabled %}
                    <small>
                        <a href="#" data-wb-cookie-trigger class="text-body-secondary text-decoration-none wb-footer-link">
                            Cookie Settings
                        </a>
                    </small>
                {% endif %}
            </div>
        {% endif %}

    </div>
</footer>
