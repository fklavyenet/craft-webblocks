{% set footerLinks = item.wbFooterLinks.all() %}
{% set brand      = item.wbNavbarBrand ?? null %}
{% set logo       = item.wbNavbarLogo.one() ?? null %}
{% set tagline    = item.wbFooterTagline ?? null %}
{% set copyright  = item.wbFooterCopyright ?? null %}

{# Auto-collect entries with wbShowInFooter enabled when no manual links are defined #}
{% if not footerLinks|length %}
    {% set autoFooterEntries = craft.entries()
        .wbShowInFooter(true)
        .all()
        |sort((a, b) =>
            (a.wbFooterOrder ? a.wbFooterOrder : 9999) - (b.wbFooterOrder ? b.wbFooterOrder : 9999)
        ) %}
{% endif %}

{% set resolvedLinks = footerLinks|length ? footerLinks : (autoFooterEntries is defined ? autoFooterEntries : []) %}

<footer class="wb-footer" style="border-top:1px solid var(--wb-border);background:var(--wb-surface-2);margin-top:auto;padding-top:3rem;padding-bottom:2rem;">
    <div class="wb-container">

        {# ── Top row: brand + links ── #}
        <div style="display:flex;flex-wrap:wrap;gap:2rem;padding-bottom:2rem;">

            {# Brand + tagline #}
            <div style="flex:0 0 auto;min-width:200px;max-width:320px;">
                {% if logo %}
                    <img src="{{ logo.url }}" alt="{{ brand ?? logo.alt ?: logo.title }}" height="32" style="display:block;margin-bottom:0.5rem;">
                {% endif %}
                {% if brand %}
                    <div style="font-weight:600;font-size:var(--wb-font-size-xl,1.125rem);margin-bottom:0.25rem;">{{ brand }}</div>
                {% endif %}
                {% if tagline %}
                    <p style="color:var(--wb-muted);font-size:0.875rem;margin:0;">{{ tagline }}</p>
                {% endif %}
            </div>

            {# Nav links #}
            {% if resolvedLinks|length %}
                <div style="flex:1;display:flex;align-items:flex-start;justify-content:flex-end;">
                    <ul class="wb-m-0 wb-p-0 wb-flex wb-flex-wrap wb-gap-3">
                        {% for link in resolvedLinks %}
                            {% if link.wbFooterLinkUrl is defined %}
                                {# manual link entry #}
                                <li>
                                    <a href="{{ link.wbFooterLinkUrl ?? '#' }}" style="color:var(--wb-muted);text-decoration:none;" class="wb-footer-link">
                                        {{ link.wbFooterLinkLabel }}
                                    </a>
                                </li>
                            {% else %}
                                {# auto entry #}
                                <li>
                                    <a href="{{ link.url }}" style="color:var(--wb-muted);text-decoration:none;" class="wb-footer-link">
                                        {{ link.title }}
                                    </a>
                                </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

        </div>

        {# ── Bottom row: copyright + cookie settings ── #}
        {% set _cs = craft.app.globals.getSetByHandle('wbCookieSettings') ?? null %}
        {% if copyright or (_cs and _cs.wbCookieBannerEnabled) %}
            <div style="border-top:1px solid var(--wb-border);padding-top:0.75rem;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:0.5rem;">
                {% if copyright %}
                    <small style="color:var(--wb-muted);">{{ copyright }}</small>
                {% endif %}
                {% if _cs and _cs.wbCookieBannerEnabled %}
                    {% set _cookieLinkLabel = {
                        'tr': 'Çerez Ayarları',
                        'de': 'Cookie-Einstellungen'
                    }[currentSite.language|slice(0,2)] ?? 'Cookie Settings' %}
                    <small>
                        <a href="#" data-wb-cookie-trigger style="color:var(--wb-muted);text-decoration:none;" class="wb-footer-link">
                            {{ _cookieLinkLabel }}
                        </a>
                    </small>
                {% endif %}
            </div>
        {% endif %}

    </div>
</footer>
