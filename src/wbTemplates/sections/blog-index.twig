{% extends "wb/layout" %}

{% set currentPage = craft.app.request.getPageNum() %}
{% set perPage = entry.wbPerPage.value ?? 10 %}
{% set postsQuery = craft.entries().section('wbBlog').orderBy('postDate desc') %}
{% set total = postsQuery.count() %}
{% set totalPages = (total / perPage)|round(0, 'ceil') %}
{% set posts = postsQuery.limit(perPage).offset((currentPage - 1) * perPage).all() %}

{# Build page URL respecting Craft's pageTrigger setting (path-based vs query-string) #}
{% set _pageTrigger = craft.app.config.general.pageTrigger %}
{% set _basePath = craft.app.request.pathInfo %}
{% macro pageUrl(basePath, trigger, pageNum) %}
    {%- if trigger starts with '?' -%}
        {{ url(basePath, {(trigger|trim('?=')): pageNum}) }}
    {%- else -%}
        {{ url(basePath ~ '/' ~ trigger ~ pageNum) }}
    {%- endif -%}
{% endmacro %}

{% block bodyClass %}page-wbblogindex{% endblock %}

{% block content %}

    {# Optional intro blocks from the index entry itself #}
    {% if entry.wbBlocks is defined and entry.wbBlocks|length %}
        {% include "wb/index" with { entry: entry } %}
    {% else %}
        <h1 class="wb-mb-6">{{ entry.title ?? "Blog"|t('webblocks') }}</h1>
    {% endif %}

    {# Post grid #}
    <div class="wb-grid-3">
        {% for post in posts %}
            <div class="wb-card" style="height:100%;">
                {% if post.wbFeaturedImage is defined %}
                    {% set img = post.wbFeaturedImage.one() %}
                    {% if img %}
                        <img src="{{ img.getUrl('wbCard') }}" alt="{{ img.alt ?: img.title }}" style="width:100%;object-fit:cover;height:200px;display:block;">
                    {% endif %}
                {% endif %}
                <div class="wb-card-body" style="display:flex;flex-direction:column;flex:1;">
                    <h5 class="wb-card-title wb-mb-2">
                        <a href="{{ post.url }}" style="text-decoration:none;color:inherit;">{{ post.title }}</a>
                    </h5>
                    {% if post.wbExcerpt is defined and post.wbExcerpt %}
                        <p style="color:var(--wb-muted);font-size:0.875rem;flex:1;">{{ post.wbExcerpt|slice(0, 150) }}{% if post.wbExcerpt|length > 150 %}…{% endif %}</p>
                    {% endif %}
                    <p style="margin-top: auto;" class="wb-mb-0">
                        <small style="color:var(--wb-muted);">{{ post.postDate|date('d.m.Y') }}</small>
                    </p>
                </div>
            </div>
        {% else %}
            <div>
                <p style="color:var(--wb-muted);">{{ "No posts yet."|t('webblocks') }}</p>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if totalPages > 1 %}
        <nav class="wb-mt-8" aria-label="{{ 'Blog post pages'|t('webblocks') }}">
            <div class="wb-pagination wb-justify-center">
                <a href="#" class="wb-page-item wb-page-item-disabled" aria-label="{{ 'Previous'|t('webblocks') }}">
                    <span aria-hidden="true">&laquo;</span>
                </a>
                {% for p in 1..totalPages %}
                    <a href="{{ _self.pageUrl(_basePath, _pageTrigger, p) }}"
                       class="wb-page-item{% if p == currentPage %} is-active{% endif %}"
                       {% if p == currentPage %}aria-current="page"{% endif %}>{{ p }}</a>
                {% endfor %}
                <a href="#" class="wb-page-item" aria-label="{{ 'Next'|t('webblocks') }}">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </div>
        </nav>
    {% endif %}

{% endblock %}
