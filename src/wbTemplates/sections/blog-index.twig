{% extends "wb/layout" %}

{% set currentPage = craft.app.request.getPageNum() %}
{% set perPage = entry.wbPerPage.value ?? 10 %}
{% set postsQuery = craft.entries().section('wbBlog').orderBy('postDate desc') %}
{% set total = postsQuery.count() %}
{% set totalPages = (total / perPage)|round(0, 'ceil') %}
{% set posts = postsQuery.limit(perPage).offset((currentPage - 1) * perPage).all() %}

{# Build page URL respecting Craft's pageTrigger setting (path-based vs query-string) #}
{% set _pageTrigger = craft.app.config.general.pageTrigger %}
{% set _basePath = craft.app.request.pathInfo %}
{% macro pageUrl(basePath, trigger, pageNum) %}
    {%- if trigger starts with '?' -%}
        {{ url(basePath, {(trigger|trim('?=')): pageNum}) }}
    {%- else -%}
        {{ url(basePath ~ '/' ~ trigger ~ pageNum) }}
    {%- endif -%}
{% endmacro %}

{% block bodyClass %}page-wbblogindex{% endblock %}

{% block content %}

    {# Optional intro blocks from the index entry itself #}
    {% if entry.wbBlocks is defined and entry.wbBlocks|length %}
        {% include "wb/index" with { entry: entry } %}
    {% else %}
        <h1 class="mb-4">{{ entry.title ?? "Blog"|t('webblocks') }}</h1>
    {% endif %}

    {# Post grid #}
    <div class="row g-4">
        {% for post in posts %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    {% if post.wbFeaturedImage is defined %}
                        {% set img = post.wbFeaturedImage.one() %}
                        {% if img %}
                            <img src="{{ img.getUrl('wbCard') }}" class="card-img-top" alt="{{ img.alt ?: img.title }}" style="object-fit:cover;height:200px;">
                        {% endif %}
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">
                            <a href="{{ post.url }}" class="text-decoration-none stretched-link text-body">{{ post.title }}</a>
                        </h5>
                        {% if post.wbExcerpt is defined and post.wbExcerpt %}
                            <p class="card-text text-muted small flex-grow-1">{{ post.wbExcerpt|slice(0, 150) }}{% if post.wbExcerpt|length > 150 %}…{% endif %}</p>
                        {% endif %}
                        <p class="card-text mt-auto">
                            <small class="text-muted">{{ post.postDate|date('d.m.Y') }}</small>
                        </p>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col">
                <p class="text-muted">{{ "No posts yet."|t('webblocks') }}</p>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if totalPages > 1 %}
        <nav class="mt-5" aria-label="{{ 'Blog post pages'|t('webblocks') }}">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ currentPage <= 1 ? 'disabled' }}">
                    {% if currentPage <= 1 %}
                        <span class="page-link" aria-label="{{ 'Previous'|t('webblocks') }}" aria-hidden="true">&laquo;</span>
                    {% else %}
                        <a class="page-link" href="{{ _self.pageUrl(_basePath, _pageTrigger, currentPage - 1) }}" aria-label="{{ 'Previous'|t('webblocks') }}">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    {% endif %}
                </li>
                {% for p in 1..totalPages %}
                    <li class="page-item {{ p == currentPage ? 'active' }}" {% if p == currentPage %}aria-current="page"{% endif %}>
                        <a class="page-link" href="{{ _self.pageUrl(_basePath, _pageTrigger, p) }}">{{ p }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {{ currentPage >= totalPages ? 'disabled' }}">
                    {% if currentPage >= totalPages %}
                        <span class="page-link" aria-label="{{ 'Next'|t('webblocks') }}" aria-hidden="true">&raquo;</span>
                    {% else %}
                        <a class="page-link" href="{{ _self.pageUrl(_basePath, _pageTrigger, currentPage + 1) }}" aria-label="{{ 'Next'|t('webblocks') }}">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    {% endif %}
                </li>
            </ul>
        </nav>
    {% endif %}

{% endblock %}
