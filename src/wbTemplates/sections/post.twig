{% extends "wb/layout" %}

{% block bodyClass %}page-wbpost page-{{ entry.slug }} page-{{ entry.id }}{% endblock %}

{% block content %}

    {# Featured image #}
    {% if entry.wbFeaturedImage is defined %}
        {% set img = entry.wbFeaturedImage.one() %}
        {% if img %}
            <img src="{{ img.getUrl('wbFeaturedImage') }}" alt="{{ img.alt ?: img.title }}" class="wb-mb-6" style="max-width:100%;height:auto;border-radius:var(--wb-r-md,0.375rem);width:100%;max-height:400px;object-fit:cover;">
        {% endif %}
    {% endif %}

    <h1>{{ entry.title }}</h1>
    <p class="wb-text-muted wb-mb-6">{{ entry.postDate|date('d.m.Y') }}</p>

    {% if entry.wbExcerpt is defined and entry.wbExcerpt %}
        <p class="wb-text-lg wb-mb-6">{{ entry.wbExcerpt }}</p>
    {% endif %}

    {% include "wb/index" with { entry: entry } %}

    {# ── Comments ───────────────────────────────────────────────────────────── #}
    <div class="wb-comments-section wb-mt-8" style="padding-top:2rem;border-top:1px solid var(--wb-border);">
        {% include "wb/partials/comment-list" with { entry: entry } %}
        {% include "wb/partials/comment-form" with { entry: entry } %}
    </div>

{% endblock %}
