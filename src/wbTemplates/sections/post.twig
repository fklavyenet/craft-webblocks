{% extends "wb/layout" %}

{% block bodyClass %}page-wbpost page-{{ entry.slug }} page-{{ entry.id }}{% endblock %}

{% block content %}

    {# Featured image #}
    {% if entry.wbFeaturedImage is defined %}
        {% set img = entry.wbFeaturedImage.one() %}
        {% if img %}
            <img src="{{ img.getUrl('wbFeaturedImage') }}" alt="{{ img.alt ?: img.title }}" style="max-width:100%;height:auto;border-radius:var(--wb-r-md,0.375rem);margin-bottom:1.5rem;width:100%;max-height:400px;object-fit:cover;">
        {% endif %}
    {% endif %}

    <h1>{{ entry.title }}</h1>
    <p style="color:var(--wb-muted);margin-bottom:1.5rem;">{{ entry.postDate|date('d.m.Y') }}</p>

    {% if entry.wbExcerpt is defined and entry.wbExcerpt %}
        <p style="font-size:var(--wb-font-size-lg,1.125rem);margin-bottom:1.5rem;">{{ entry.wbExcerpt }}</p>
    {% endif %}

    {% include "wb/index" with { entry: entry } %}

    {# ── Comments ───────────────────────────────────────────────────────────── #}
    <div class="wb-comments-section" style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--wb-border);">
        {% include "wb/partials/comment-list" with { entry: entry } %}
        {% include "wb/partials/comment-form" with { entry: entry } %}
    </div>

{% endblock %}
