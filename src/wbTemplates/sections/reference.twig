{% extends "wb/layout" %}

{% block bodyClass %}page-wbreference page-{{ entry.slug }} page-{{ entry.id }}{% endblock %}

{% block content %}

    {# Featured image #}
    {% if entry.wbFeaturedImage is defined %}
        {% set img = entry.wbFeaturedImage.one() %}
        {% if img %}
            <img src="{{ img.getUrl('wbFeaturedImage') }}" alt="{{ img.alt ?: img.title }}" class="img-fluid rounded mb-4 w-100" style="max-height:400px;object-fit:cover;">
        {% endif %}
    {% endif %}

    <h1>{{ entry.title }}</h1>

    {% if entry.wbExcerpt is defined and entry.wbExcerpt %}
        <p class="lead mb-4">{{ entry.wbExcerpt }}</p>
    {% endif %}

    {% include "wb/index" with { entry: entry } %}

{% endblock %}
