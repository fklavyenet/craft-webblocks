{% extends "wb/layout" %}

{% set currentPage = craft.app.request.getPageNum() %}
{% set perPage = 12 %}
{% set refsQuery = craft.entries().section('wbReferences').orderBy('postDate desc') %}
{% set total = refsQuery.count() %}
{% set totalPages = (total / perPage)|round(0, 'ceil') %}
{% set references = refsQuery.limit(perPage).offset((currentPage - 1) * perPage).all() %}

{% block bodyClass %}page-wbreferencesindex{% endblock %}

{% block content %}

    {# Optional intro blocks from the index entry itself #}
    {% if entry.wbBlocks is defined and entry.wbBlocks|length %}
        {% include "wb/index" with { entry: entry } %}
    {% else %}
        <h1 style="margin-bottom:1.5rem;">{{ entry.title ?? "References"|t('webblocks') }}</h1>
    {% endif %}

    {# References grid #}
    <div class="wb-grid-3">
        {% for ref in references %}
            <div class="wb-card" style="height:100%;">
                {% if ref.wbFeaturedImage is defined %}
                    {% set img = ref.wbFeaturedImage.one() %}
                    {% if img %}
                        <img src="{{ img.getUrl('wbCard') }}" alt="{{ img.alt ?: img.title }}" style="width:100%;object-fit:cover;height:200px;display:block;">
                    {% endif %}
                {% endif %}
                <div class="wb-card-body" style="display:flex;flex-direction:column;flex:1;">
                    <h5 class="wb-card-title wb-mb-2">
                        <a href="{{ ref.url }}" style="text-decoration:none;color:inherit;">{{ ref.title }}</a>
                    </h5>
                    {% if ref.wbExcerpt is defined and ref.wbExcerpt %}
                        <p style="color:var(--wb-muted);font-size:0.875rem;flex:1;">{{ ref.wbExcerpt|slice(0, 150) }}{% if ref.wbExcerpt|length > 150 %}…{% endif %}</p>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div>
                <p style="color:var(--wb-muted);">{{ "No references yet."|t('webblocks') }}</p>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if totalPages > 1 %}
        <nav style="margin-top:3rem;" aria-label="{{ 'Reference pages'|t('webblocks') }}">
            <div class="wb-pagination wb-justify-center">
                <a href="#" class="wb-page-item wb-page-item-disabled" aria-label="{{ 'Previous'|t('webblocks') }}">
                    <span aria-hidden="true">&laquo;</span>
                </a>
                {% for p in 1..totalPages %}
                    <a href="#" class="wb-page-item{% if p == currentPage %} is-active{% endif %}"
                       {% if p == currentPage %}aria-current="page"{% endif %}>{{ p }}</a>
                {% endfor %}
                <a href="#" class="wb-page-item" aria-label="{{ 'Next'|t('webblocks') }}">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </div>
        </nav>
    {% endif %}

{% endblock %}
