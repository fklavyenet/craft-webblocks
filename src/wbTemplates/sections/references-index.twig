{% extends "wb/layout" %}

{% set currentPage = craft.app.request.getPageNum() %}
{% set perPage = 12 %}
{% set refsQuery = craft.entries().section('wbReferences').orderBy('postDate desc') %}
{% set total = refsQuery.count() %}
{% set totalPages = (total / perPage)|round(0, 'ceil') %}
{% set references = refsQuery.limit(perPage).offset((currentPage - 1) * perPage).all() %}

{% block bodyClass %}page-wbreferencesindex{% endblock %}

{% block title %}<title>{{ entry.wbSeoTitle ?? entry.title ?? "References"|t('webblocks') }} — {{ siteName }}</title>{% endblock %}

{% block content %}

    {# Optional intro blocks from the index entry itself #}
    {% if entry.wbBlocks is defined and entry.wbBlocks|length %}
        {% include "wb/index" with { entry: entry } %}
    {% else %}
        <h1 class="mb-4">{{ entry.title ?? "References"|t('webblocks') }}</h1>
    {% endif %}

    {# References grid #}
    <div class="row g-4">
        {% for ref in references %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    {% if ref.wbFeaturedImage is defined %}
                        {% set img = ref.wbFeaturedImage.one() %}
                        {% if img %}
                            <img src="{{ img.getUrl('wbCard') }}" class="card-img-top" alt="{{ img.alt ?: img.title }}" style="object-fit:cover;height:200px;">
                        {% endif %}
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">
                            <a href="{{ ref.url }}" class="text-decoration-none stretched-link text-body">{{ ref.title }}</a>
                        </h5>
                        {% if ref.wbExcerpt is defined and ref.wbExcerpt %}
                            <p class="card-text text-muted small flex-grow-1">{{ ref.wbExcerpt|slice(0, 150) }}{% if ref.wbExcerpt|length > 150 %}…{% endif %}</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col">
                <p class="text-muted">{{ "No references yet."|t('webblocks') }}</p>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if totalPages > 1 %}
        <nav class="mt-5" aria-label="{{ 'Reference pages'|t('webblocks') }}">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ currentPage <= 1 ? 'disabled' }}">
                    <a class="page-link" href="{{ url(craft.app.request.pathInfo, {p: currentPage - 1}) }}" aria-label="{{ 'Previous'|t('webblocks') }}">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>
                {% for p in 1..totalPages %}
                    <li class="page-item {{ p == currentPage ? 'active' }}" {% if p == currentPage %}aria-current="page"{% endif %}>
                        <a class="page-link" href="{{ url(craft.app.request.pathInfo, {p: p}) }}">{{ p }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {{ currentPage >= totalPages ? 'disabled' }}">
                    <a class="page-link" href="{{ url(craft.app.request.pathInfo, {p: currentPage + 1}) }}" aria-label="{{ 'Next'|t('webblocks') }}">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
    {% endif %}

{% endblock %}
