{% extends "wb/layout" %}

{# Services index: list child service pages #}
{% if entry.type.handle == 'wbServicesIndex' %}
    {% set children = craft.entries().section('wbServices').descendantOf(entry).level(entry.level + 1).all() %}
{% endif %}

{% block bodyClass %}page-{{ entry.type.handle|lower }} page-{{ entry.slug }} page-{{ entry.id }}{% endblock %}

{% block title %}<title>{{ entry.wbSeoTitle ?? entry.title }} — {{ siteName }}</title>{% endblock %}

{% block content %}

    {% include "wb/index" with { entry: entry } %}

    {# If this is the services index, show child service cards below any blocks #}
    {% if entry.type.handle == 'wbServicesIndex' and children is defined and children|length %}
        <div class="row g-4 mt-2">
            {% for child in children %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">
                                <a href="{{ child.url }}" class="text-decoration-none stretched-link text-body">{{ child.title }}</a>
                            </h5>
                            {% if child.wbExcerpt is defined and child.wbExcerpt %}
                                <p class="card-text text-muted small flex-grow-1">{{ child.wbExcerpt|slice(0, 150) }}{% if child.wbExcerpt|length > 150 %}…{% endif %}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

{% endblock %}
